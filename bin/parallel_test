#!/usr/bin/env ruby
# frozen_string_literal: true

require "pathname"
ENV["BUNDLE_GEMFILE"] ||= File.expand_path("../../Gemfile",
  Pathname.new(__FILE__).realpath)

require "bundler/setup"
require "optparse"

options = {
  processes: ENV.fetch("PARALLEL_TEST_PROCESSES", 10),
  setup: false,
  exclude_system: true,
  runtime_log: ENV.fetch("PARALLEL_RUNTIME_LOG", "tmp/parallel_runtime_rspec.log"),
  failures_log: ENV.fetch("PARALLEL_FAILURES_LOG", "tmp/failing_specs.txt")
}

OptionParser.new do |opts|
  opts.banner = "Usage: bin/parallel_test [options] [spec_files]"

  opts.on("-n", "--processes N", Integer, "Number of parallel processes (default: 10)") do |n|
    options[:processes] = n
  end

  opts.on("-s", "--setup", "Setup test databases before running") do
    options[:setup] = true
  end

  opts.on("-e", "--exclude-system", "Exclude system specs") do
    options[:exclude_system] = true
  end

  opts.on("-i", "--include-system", "Include system specs") do
    options[:exclude_system] = false
  end

  opts.on("--runtime-log PATH", "Runtime log file path") do |path|
    options[:runtime_log] = path
  end

  opts.on("--failures-log PATH", "Failures log file path") do |path|
    options[:failures_log] = path
  end

  opts.on("-h", "--help", "Show this help message") do
    puts opts
    exit
  end
end.parse!

# Set up database for parallel tests if requested
if options[:setup]
  puts "Setting up parallel test databases..."
  setup_env = { "PARALLEL_TEST_PROCESSORS" => options[:processes].to_s }
  setup_ok = system(setup_env, "mise", "exec", "--", "bin/parallel_setup")
  exit(1) unless setup_ok
end

# Build the command
command = [
  "mise", "exec", "--", "bundle", "exec", "parallel_rspec",
  "-n", options[:processes].to_s,
  "--runtime-log", options[:runtime_log]
]
parallel_env = {
  "PARALLEL_RUNTIME_LOG" => options[:runtime_log],
  "PARALLEL_FAILURES_LOG" => options[:failures_log]
}

if File.exist?(options[:runtime_log]) && !File.zero?(options[:runtime_log])
  command.concat(["--group-by", "runtime"])
end

# Add spec files or directories
if ARGV.empty?
  if options[:exclude_system]
    command << "spec"
    command.concat(["--exclude-pattern", "spec/(system|system_skip)/"])
  else
    command << "spec"
  end
else
  command.concat(ARGV)
end

puts "Running tests with #{options[:processes]} parallel processes..."
puts "Command: #{command.join(" ")}"
exec(parallel_env, *command)
