#!/usr/bin/env bash
set -euo pipefail

if command -v sysctl >/dev/null 2>&1; then
  CPU_COUNT="$(sysctl -n hw.logicalcpu)"
elif command -v nproc >/dev/null 2>&1; then
  CPU_COUNT="$(nproc)"
else
  CPU_COUNT="4"
fi

PROCS="${PARALLEL_TEST_PROCESSORS:-$CPU_COUNT}"
ARGS=("$@")
RUNTIME_LOG="${PARALLEL_RUNTIME_LOG:-tmp/parallel_runtime_system.log}"
QUIET="${SYSTEM_SPECS_QUIET:-1}"

if [ "${#ARGS[@]}" -eq 0 ]; then
  ARGS=("spec/system")
fi

echo "Preparing parallel test databases for ${PROCS} processes..."
mise exec -- bundle exec rake "parallel:create[${PROCS}]" "parallel:load_schema[${PROCS}]"

echo "Running system specs in parallel (${PROCS} processes)..."
BASE_CMD=(mise exec -- bundle exec parallel_rspec "${ARGS[@]}" -n "${PROCS}" --runtime-log "${RUNTIME_LOG}")

if [ -f "${RUNTIME_LOG}" ]; then
  BASE_CMD+=(--group-by runtime)
fi

if [ "${QUIET}" = "1" ]; then
  BASE_CMD+=(--serialize-stdout --combine-stderr --quiet --test-options "--format progress")
fi

CI=true "${BASE_CMD[@]}"
