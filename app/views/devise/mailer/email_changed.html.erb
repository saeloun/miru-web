<% content_for :email_preheader, "Your Miru email address has changed." %>
<% content_for :email_eyebrow, "Account security" %>
<% content_for :email_title, "Email address updated" %>
<% content_for :email_subtitle do %>
  This message confirms a change to the email address on your Miru account.
<% end %>

<p>Hello <strong><%= @email %></strong>,</p>

<% if @resource.try(:unconfirmed_email?) %>
  <p>Your account email is being changed to <strong><%= @resource.unconfirmed_email %></strong>.</p>
<% else %>
  <p>Your account email has been changed to <strong><%= @resource.email %></strong>.</p>
<% end %>

<div class="email-panel email-panel-warning">
  <p class="email-panel-title">Did not request this change?</p>
  <p style="margin-bottom: 0;">Contact our support team immediately at <a href="mailto:hello@saeloun.com">hello@saeloun.com</a>.</p>
</div>

<p>Thanks,<br><strong>Team Miru</strong></p>
