<% content_for :email_preheader, t("mailers.devise.email_changed.preheader") %>
<% content_for :email_eyebrow, t("mailers.devise.email_changed.eyebrow") %>
<% content_for :email_title, t("mailers.devise.email_changed.title") %>
<% content_for :email_subtitle do %>
  <%= t("mailers.devise.email_changed.subtitle") %>
<% end %>

<p><%= t("mailers.devise.email_changed.greeting_html", email: @email) %></p>

<% if @resource.try(:unconfirmed_email?) %>
  <p><%= t("mailers.devise.email_changed.pending_html", email: @resource.unconfirmed_email) %></p>
<% else %>
  <p><%= t("mailers.devise.email_changed.changed_html", email: @resource.email) %></p>
<% end %>

<div class="email-panel email-panel-warning">
  <p class="email-panel-title"><%= t("mailers.devise.email_changed.warning_title") %></p>
  <p style="margin-bottom: 0;"><%= t("mailers.devise.email_changed.warning_body_html", email: "hello@saeloun.com") %></p>
</div>

<p><%= t("mailers.devise.shared.signature_html") %></p>
