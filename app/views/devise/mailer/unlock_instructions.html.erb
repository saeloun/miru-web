<% content_for :email_preheader, t("mailers.devise.unlock.preheader") %>
<% content_for :email_eyebrow, t("mailers.devise.unlock.eyebrow") %>
<% content_for :email_title, t("mailers.devise.unlock.title") %>
<% content_for :email_subtitle do %>
  <%= t("mailers.devise.unlock.subtitle") %>
<% end %>

<p><%= t("mailers.devise.unlock.greeting_html", email: @resource.email) %></p>

<div class="email-panel email-panel-danger">
  <p class="email-panel-title"><%= t("mailers.devise.unlock.warning_title") %></p>
  <p style="margin-bottom: 0;"><%= t("mailers.devise.unlock.warning_body") %></p>
</div>

<%= render "shared/mailer/button", href: "#{ENV.fetch("APP_BASE_URL", "http://127.0.0.1:3000")}/password/new", label: t("mailers.devise.unlock.cta") %>

<div class="email-divider"></div>

<p class="email-muted"><%= t("mailers.devise.unlock.footer_note") %></p>

<p><%= t("mailers.devise.shared.signature_html") %></p>
