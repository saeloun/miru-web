<% content_for :email_preheader, t("mailers.devise.reset_password.preheader") %>
<% content_for :email_eyebrow, t("mailers.devise.reset_password.eyebrow") %>
<% content_for :email_title, t("mailers.devise.reset_password.title") %>
<% content_for :email_subtitle do %>
  <%= t("mailers.devise.reset_password.subtitle") %>
<% end %>

<p><%= t("mailers.devise.reset_password.greeting") %></p>

<p><%= t("mailers.devise.reset_password.request_html", email: @resource.email) %></p>

<p><%= t("mailers.devise.reset_password.cta_body") %></p>

<%= render "shared/mailer/button", href: edit_password_url(@resource, reset_password_token: @token), label: t("mailers.devise.reset_password.cta") %>

<div class="email-divider"></div>

<p class="email-muted"><%= t("mailers.devise.reset_password.footer_note") %></p>
