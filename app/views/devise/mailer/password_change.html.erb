<% content_for :email_preheader, "Your Miru password has been changed." %>
<% content_for :email_eyebrow, "Account security" %>
<% content_for :email_title, "Password changed successfully" %>
<% content_for :email_subtitle do %>
  Your account is now secured with your new password.
<% end %>

<p>Hello <strong><%= @resource.first_name %></strong>,</p>

<div class="email-panel email-panel-success">
  <p class="email-panel-title">Your password was updated.</p>
  <p style="margin-bottom: 0;">You can continue signing in to Miru using your new password.</p>
</div>

<div class="email-panel email-panel-warning">
  <p class="email-panel-title">Did not make this change?</p>
  <p style="margin-bottom: 0;">Contact <a href="mailto:hello@saeloun.com">hello@saeloun.com</a> right away so we can help secure your account.</p>
</div>

<p>Cheers,<br><strong>Team Miru</strong></p>
