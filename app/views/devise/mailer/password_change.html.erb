<% content_for :email_preheader, t("mailers.devise.password_change.preheader") %>
<% content_for :email_eyebrow, t("mailers.devise.password_change.eyebrow") %>
<% content_for :email_title, t("mailers.devise.password_change.title") %>
<% content_for :email_subtitle do %>
  <%= t("mailers.devise.password_change.subtitle") %>
<% end %>

<p><%= t("mailers.devise.password_change.greeting_html", name: @resource.first_name) %></p>

<div class="email-panel email-panel-success">
  <p class="email-panel-title"><%= t("mailers.devise.password_change.success_title") %></p>
  <p style="margin-bottom: 0;"><%= t("mailers.devise.password_change.success_body") %></p>
</div>

<div class="email-panel email-panel-warning">
  <p class="email-panel-title"><%= t("mailers.devise.password_change.warning_title") %></p>
  <p style="margin-bottom: 0;"><%= t("mailers.devise.password_change.warning_body_html", email: "hello@saeloun.com") %></p>
</div>

<p><%= t("mailers.devise.shared.signature_html") %></p>
