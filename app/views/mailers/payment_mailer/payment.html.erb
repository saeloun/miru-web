<% content_for :email_preheader, "Payment confirmation for invoice #{@invoice.invoice_number}." %>
<% content_for :email_eyebrow, "Payments" %>
<% content_for :email_title, "Payment confirmation" %>
<% content_for :email_subtitle do %>
  <strong><%= @invoice.client.name %></strong> has completed payment for invoice <strong><%= @invoice.invoice_number %></strong>.
<% end %>

<div class="email-panel email-panel-success">
  <%= sanitize @message %>
</div>

<table role="presentation" width="100%" cellpadding="0" cellspacing="0" border="0" class="detail-grid">
  <tr>
    <%= render "shared/mailer/detail_card", label: "Invoice", value: @invoice.invoice_number %>
    <%= render "shared/mailer/detail_card", label: "Amount paid", value: @amount %>
  </tr>
  <tr>
    <%= render "shared/mailer/detail_card",
      label: "Payment method",
      value: @invoice.payments.any?(&:present?) ? @invoice.payments.pluck(:transaction_type).to_sentence.upcase : "STRIPE" %>
    <%= render "shared/mailer/detail_card", label: "Client", value: @invoice.client.name %>
  </tr>
</table>

<%= render "shared/mailer/button", href: @invoice_url, label: "View invoice" %>
