<% content_for :email_preheader, t("mailers.payment_mailer.payment.preheader", invoice_number: @invoice.invoice_number) %>
<% content_for :email_eyebrow, t("mailers.payment_mailer.payment.eyebrow") %>
<% content_for :email_title, t("mailers.payment_mailer.payment.title") %>
<% content_for :email_subtitle do %>
  <%= t("mailers.payment_mailer.payment.subtitle_html", client_name: @invoice.client.name, invoice_number: @invoice.invoice_number).html_safe %>
<% end %>

<div class="email-highlight">
  <p class="email-highlight-label"><%= t("mailers.labels.amount_paid") %></p>
  <p class="email-highlight-value"><%= @amount %></p>
  <p class="email-highlight-caption"><%= sanitize(@message) %></p>
</div>

<%= render "shared/mailer/fact_rows", rows: [
  { label: t("mailers.labels.invoice"), value: @invoice.invoice_number },
  { label: t("mailers.labels.client"), value: @invoice.client.name },
  { label: t("mailers.labels.payment_method"), value: @invoice.payments.any?(&:present?) ? @invoice.payments.pluck(:transaction_type).to_sentence.upcase : "STRIPE" }
] %>

<%= render "shared/mailer/button", href: @invoice_url, label: t("mailers.actions.open_invoice") %>

<p class="email-muted" style="margin-top: 18px;"><strong><%= t("mailers.payment_mailer.payment.follow_up_title") %></strong> <%= t("mailers.payment_mailer.payment.follow_up_body") %></p>
