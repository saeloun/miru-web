<p class="email-eyebrow">Monthly Digest</p>
<h1 class="email-title"><%= @company.name %>'s <%= @digest[:month_label] %> cash flow digest</h1>
<p class="email-subtitle">
  Here's your snapshot of money moving through Miru for <%= @digest[:month_year_label] %>.
</p>

<div class="email-panel <%= @digest[:net_change] >= 0 ? "email-panel-success" : "email-panel-danger" %>">
  <p class="digest-kicker">Net change in <%= @digest[:month_label] %></p>
  <p class="digest-value"><%= FormatAmountService.new(@digest[:currency], @digest[:net_change]).process %></p>
  <p class="digest-caption">
    Average daily net change
    <strong><%= FormatAmountService.new(@digest[:currency], @digest[:average_daily_net_change]).process %></strong>
  </p>

  <table role="presentation" width="100%" cellpadding="0" cellspacing="0" border="0" class="digest-trend-table">
    <tr>
      <% @digest[:trend_points].each do |point| %>
        <td class="digest-trend-cell" title="<%= "#{point[:label]}: #{FormatAmountService.new(@digest[:currency], point[:amount]).process}" %>">
          <div class="digest-trend-bar" style="height: <%= point[:height] %>px;"></div>
        </td>
      <% end %>
    </tr>
  </table>

  <table role="presentation" width="100%" cellpadding="0" cellspacing="0" border="0" class="digest-trend-labels">
    <tr>
      <td><%= @digest[:trend_points].first[:label] %></td>
      <td align="center"><%= @digest[:trend_points][(@digest[:trend_points].size / 2.0).floor][:label] %></td>
      <td align="right"><%= @digest[:trend_points].last[:label] %></td>
    </tr>
  </table>
</div>

<table role="presentation" width="100%" cellpadding="0" cellspacing="0" border="0" class="detail-grid">
  <tr>
    <%= render "shared/mailer/detail_card",
      label: "Money in",
      value: FormatAmountService.new(@digest[:currency], @digest[:money_in_total]).process,
      subvalue: "vs. #{FormatAmountService.new(@digest[:currency], @digest[:previous_money_in_total]).process} in #{@digest[:period_start].prev_month.strftime('%B')}" %>
    <%= render "shared/mailer/detail_card",
      label: "Money out",
      value: FormatAmountService.new(@digest[:currency], @digest[:money_out_total]).process,
      subvalue: "vs. #{FormatAmountService.new(@digest[:currency], @digest[:previous_money_out_total]).process} in #{@digest[:period_start].prev_month.strftime('%B')}" %>
  </tr>
</table>

<div class="email-panel email-panel-soft">
  <p class="email-panel-title">Top money-in sources</p>
  <table role="presentation" width="100%" cellpadding="0" cellspacing="0" border="0">
    <% if @digest[:top_money_in_sources].any? %>
      <% @digest[:top_money_in_sources].each do |source| %>
        <tr>
          <td class="digest-source-name"><%= source[:name] %></td>
          <td class="digest-source-amount" align="right"><%= FormatAmountService.new(@digest[:currency], source[:amount]).process %></td>
        </tr>
      <% end %>
    <% else %>
      <tr>
        <td class="digest-empty-state">No payments were recorded in Miru for <%= @digest[:month_year_label] %>.</td>
      </tr>
    <% end %>
  </table>
</div>

<div class="email-panel email-panel-soft">
  <p class="email-panel-title">Top money-out buckets</p>
  <table role="presentation" width="100%" cellpadding="0" cellspacing="0" border="0">
    <% if @digest[:top_money_out_sources].any? %>
      <% @digest[:top_money_out_sources].each do |source| %>
        <tr>
          <td class="digest-source-name"><%= source[:name] %></td>
          <td class="digest-source-amount" align="right"><%= FormatAmountService.new(@digest[:currency], source[:amount]).process %></td>
        </tr>
      <% end %>
    <% else %>
      <tr>
        <td class="digest-empty-state">No paid expenses were recorded in Miru for <%= @digest[:month_year_label] %>.</td>
      </tr>
    <% end %>
  </table>
</div>

<%= render "shared/mailer/button", href: @reports_url, label: "View reports in Miru" %>
