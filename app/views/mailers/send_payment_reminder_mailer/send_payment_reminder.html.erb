<% content_for :email_preheader, "Payment reminder for #{@company.name} invoices." %>
<% content_for :email_eyebrow, "Invoices" %>
<% content_for :email_title, "Payment reminder" %>
<% content_for :email_subtitle do %>
  Review the invoices below and pay any balances that are still outstanding.
<% end %>

<div class="email-panel email-panel-warning">
  <%= simple_format(sanitize(@message), {}, wrapper_tag: "div") %>
</div>

<% @invoices.each do |invoice| %>
  <div class="email-panel email-panel-soft">
    <p class="email-panel-title" style="margin-bottom: 16px;"><%= invoice.invoice_number %></p>
    <table role="presentation" width="100%" cellpadding="0" cellspacing="0" border="0" class="detail-grid">
      <tr>
        <%= render "shared/mailer/detail_card",
          label: "Issue date",
          value: CompanyDateFormattingService.new(invoice.issue_date, company: @company).process %>
        <%= render "shared/mailer/detail_card", label: "Due date", value: invoice.due_date.strftime("%B %d, %Y") %>
      </tr>
      <tr>
        <%= render "shared/mailer/detail_card", label: "Amount due", value: FormatAmountService.new(@company.base_currency, invoice.amount).process %>
        <%= render "shared/mailer/detail_card", label: "Status", value: invoice.status.humanize %>
      </tr>
    </table>
    <%= render "shared/mailer/button", href: "#{ENV['APP_BASE_URL']}/invoices/#{invoice.external_view_key}/view", label: "Review invoice" %>
  </div>
<% end %>
