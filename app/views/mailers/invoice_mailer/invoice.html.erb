<% content_for :email_preheader, "Invoice #{@invoice.invoice_number} from #{@invoice.company.name}." %>
<% content_for :email_eyebrow, "Invoices" %>
<% content_for :email_title, "Invoice summary" %>
<% content_for :email_subtitle do %>
  <strong><%= @invoice.company.name %></strong> has sent you invoice <strong><%= @invoice.invoice_number %></strong>.
<% end %>

<table role="presentation" width="100%" cellpadding="0" cellspacing="0" border="0" class="detail-grid">
  <tr>
    <%= render "shared/mailer/detail_card", label: "Issue date", value: @invoice.issue_date.ordinalize %>
    <%= render "shared/mailer/detail_card", label: "Due date", value: @invoice.due_date.ordinalize %>
  </tr>
  <tr>
    <%= render "shared/mailer/detail_card", label: "Invoice number", value: @invoice.invoice_number %>
    <%= render "shared/mailer/detail_card", label: "Reference", value: @invoice.reference.presence || "-" %>
  </tr>
  <tr>
    <%= render "shared/mailer/detail_card", label: "Amount due", value: @amount || "-" %>
    <%= render "shared/mailer/detail_card", label: "Payment link", value: "Hosted invoice page", subvalue: "Open the invoice to review line items and complete payment online." %>
  </tr>
</table>

<%= render "shared/mailer/button", href: @invoice_url, label: "View invoice" %>
