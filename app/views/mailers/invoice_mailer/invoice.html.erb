<% content_for :email_preheader, t("mailers.invoice_mailer.invoice.preheader", invoice_number: @invoice.invoice_number, company_name: @invoice.company.name) %>
<% content_for :email_eyebrow, t("mailers.invoice_mailer.invoice.eyebrow") %>
<% content_for :email_title, t("mailers.invoice_mailer.invoice.title") %>
<% content_for :email_subtitle do %>
  <%= t("mailers.invoice_mailer.invoice.subtitle_html", company_name: @invoice.company.name, invoice_number: @invoice.invoice_number).html_safe %>
<% end %>

<%
  rows = [
    { label: t("mailers.labels.invoice_number"), value: @invoice.invoice_number },
    { label: t("mailers.labels.due_date"), value: l(@invoice.due_date.to_date, format: :long) },
    { label: t("mailers.labels.issue_date"), value: l(@invoice.issue_date.to_date, format: :long) },
    { label: t("mailers.labels.payment_link"), value: t("mailers.invoice_mailer.invoice.payment_link_value") }
  ]
  rows << { label: t("mailers.labels.reference"), value: @invoice.reference } if @invoice.reference.present?
%>

<div class="email-highlight">
  <p class="email-highlight-label"><%= t("mailers.labels.amount_due") %></p>
  <p class="email-highlight-value"><%= @amount || "-" %></p>
</div>

<div class="email-panel email-panel-accent">
  <p class="email-panel-title"><%= t("mailers.invoice_mailer.invoice.ready_title") %></p>
  <p style="margin: 0;"><%= t("mailers.invoice_mailer.invoice.ready_body") %></p>
</div>

<%= render "shared/mailer/fact_rows", rows: rows %>

<%= render "shared/mailer/button", href: @invoice_url, label: t("mailers.actions.open_invoice") %>

<p class="email-muted" style="margin-top: 18px;"><%= t("mailers.invoice_mailer.invoice.support_html", support_email: t("mailers.layout.footer_contact")).html_safe %></p>
