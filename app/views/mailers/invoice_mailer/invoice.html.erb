<% content_for :email_preheader, t("mailers.invoice_mailer.invoice.preheader", invoice_number: @invoice.invoice_number, company_name: @invoice.company.name) %>
<% content_for :email_eyebrow, t("mailers.invoice_mailer.invoice.eyebrow") %>
<% content_for :email_title, t("mailers.invoice_mailer.invoice.title") %>
<% content_for :email_subtitle do %>
  <%= t("mailers.invoice_mailer.invoice.subtitle_html", company_name: @invoice.company.name, invoice_number: @invoice.invoice_number).html_safe %>
<% end %>

<table role="presentation" width="100%" cellpadding="0" cellspacing="0" border="0" class="detail-grid">
  <tr>
    <%= render "shared/mailer/detail_card", label: t("mailers.labels.issue_date"), value: l(@invoice.issue_date.to_date, format: :long) %>
    <%= render "shared/mailer/detail_card", label: t("mailers.labels.due_date"), value: l(@invoice.due_date.to_date, format: :long) %>
  </tr>
  <tr>
    <%= render "shared/mailer/detail_card", label: t("mailers.labels.invoice_number"), value: @invoice.invoice_number %>
    <%= render "shared/mailer/detail_card", label: t("mailers.labels.reference"), value: @invoice.reference.presence || "-" %>
  </tr>
  <tr>
    <%= render "shared/mailer/detail_card", label: t("mailers.labels.amount_due"), value: @amount || "-" %>
    <%= render "shared/mailer/detail_card", label: t("mailers.labels.payment_link"), value: t("mailers.invoice_mailer.invoice.payment_link_value"), subvalue: t("mailers.invoice_mailer.invoice.payment_link_subvalue") %>
  </tr>
</table>

<%= render "shared/mailer/button", href: @invoice_url, label: t("mailers.actions.open_invoice") %>
