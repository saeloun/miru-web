<% content_for :email_preheader, "Reminder for invoice #{@invoice.invoice_number} from #{@invoice.company.name}." %>
<% content_for :email_eyebrow, "Invoices" %>
<% content_for :email_title, "Payment reminder" %>
<% content_for :email_subtitle do %>
  Invoice <strong><%= @invoice.invoice_number %></strong> from <strong><%= @invoice.company.name %></strong> is still awaiting payment.
<% end %>

<% if @message.present? %>
  <div class="email-panel email-panel-warning">
    <%= simple_format(@message, {}, wrapper_tag: "div") %>
  </div>
<% end %>

<table role="presentation" width="100%" cellpadding="0" cellspacing="0" border="0" class="detail-grid">
  <tr>
    <%= render "shared/mailer/detail_card", label: "Issue date", value: @invoice.issue_date.strftime("%B %d, %Y") %>
    <%= render "shared/mailer/detail_card", label: "Due date", value: @invoice.due_date.strftime("%B %d, %Y") %>
  </tr>
  <tr>
    <%= render "shared/mailer/detail_card", label: "Invoice number", value: @invoice.invoice_number %>
    <%= render "shared/mailer/detail_card", label: "Reference", value: @invoice.reference.presence || "-" %>
  </tr>
  <tr>
    <%= render "shared/mailer/detail_card", label: "Outstanding amount", value: @amount %>
    <%= render "shared/mailer/detail_card", label: "Status", value: @invoice.status.humanize %>
  </tr>
</table>

<%= render "shared/mailer/button", href: @invoice_url, label: "Review invoice" %>
