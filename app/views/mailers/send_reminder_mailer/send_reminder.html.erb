<% content_for :email_preheader, t("mailers.send_reminder_mailer.send_reminder.preheader", invoice_number: @invoice.invoice_number, company_name: @invoice.company.name) %>
<% content_for :email_eyebrow, t("mailers.send_reminder_mailer.send_reminder.eyebrow") %>
<% content_for :email_title, t("mailers.send_reminder_mailer.send_reminder.title") %>
<% content_for :email_subtitle do %>
  <%= t("mailers.send_reminder_mailer.send_reminder.subtitle_html", invoice_number: @invoice.invoice_number, company_name: @invoice.company.name).html_safe %>
<% end %>

<% if @message.present? %>
  <div class="email-panel email-panel-warning">
    <%= simple_format(@message, {}, wrapper_tag: "div") %>
  </div>
<% end %>

<table role="presentation" width="100%" cellpadding="0" cellspacing="0" border="0" class="detail-grid">
  <tr>
    <%= render "shared/mailer/detail_card", label: t("mailers.labels.issue_date"), value: l(@invoice.issue_date.to_date, format: :long) %>
    <%= render "shared/mailer/detail_card", label: t("mailers.labels.due_date"), value: l(@invoice.due_date.to_date, format: :long) %>
  </tr>
  <tr>
    <%= render "shared/mailer/detail_card", label: t("mailers.labels.invoice_number"), value: @invoice.invoice_number %>
    <%= render "shared/mailer/detail_card", label: t("mailers.labels.reference"), value: @invoice.reference.presence || "-" %>
  </tr>
  <tr>
    <%= render "shared/mailer/detail_card", label: t("mailers.labels.outstanding_amount"), value: @amount %>
    <%= render "shared/mailer/detail_card", label: t("mailers.labels.status"), value: @invoice.status.humanize %>
  </tr>
</table>

<%= render "shared/mailer/button", href: @invoice_url, label: t("mailers.actions.open_invoice") %>
