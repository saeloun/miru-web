<% content_for :email_preheader, "You have been invited to join a team on Miru." %>
<% content_for :email_eyebrow, "Invitation" %>
<% content_for :email_title, "You have been invited to Miru" %>
<% content_for :email_subtitle do %>
  <strong><%= @sender_details&.[](:name) %></strong> invited you to join <strong><%= @company_details&.[](:name) %></strong>.
<% end %>

<table role="presentation" width="100%" cellpadding="0" cellspacing="0" border="0" class="detail-grid">
  <tr>
    <%= render "shared/mailer/detail_card",
      label: "Invited by",
      value: @sender_details&.[](:name),
      subvalue: @sender_details&.[](:email) %>
    <%= render "shared/mailer/detail_card",
      label: "Workspace",
      value: @company_details&.[](:name),
      subvalue: "#{@company_details&.[](:employee_count)} members" %>
  </tr>
</table>

<div class="email-panel email-panel-accent">
  <p class="email-panel-title">Get started</p>
  <p style="margin-bottom: 0;">Set your password, join the workspace, and start collaborating in Miru.</p>
</div>

<%= render "shared/mailer/button", href: invitations_accepts_url(token: @token), label: "Join Miru" %>

<div class="email-divider"></div>

<p>If this invitation was not expected, please flag it with our team at <a href="mailto:hello@saeloun.com">hello@saeloun.com</a>.</p>

<div class="email-panel email-panel-soft">
  <p class="email-panel-title">About Miru</p>
  <p style="margin-bottom: 0;">Miru helps teams track time, send invoices, collect payments, and manage day-to-day billing operations without leaving a single workspace.</p>
</div>
