<% content_for :email_preheader, t("mailers.expense_mailer.rejected.preheader") %>
<% content_for :email_eyebrow, t("mailers.expense_mailer.rejected.eyebrow") %>
<% content_for :email_title, t("mailers.expense_mailer.rejected.title") %>
<% content_for :email_subtitle do %>
  <%= t("mailers.expense_mailer.rejected.subtitle") %>
<% end %>

<table role="presentation" width="100%" cellpadding="0" cellspacing="0" border="0" class="detail-grid">
  <tr>
    <%= render "shared/mailer/detail_card", label: t("mailers.labels.amount"), value: FormatAmountService.new(@company.base_currency, @expense.amount).process %>
    <%= render "shared/mailer/detail_card", label: t("mailers.labels.category"), value: @expense.display_category_name.presence || "-" %>
  </tr>
  <tr>
    <%= render "shared/mailer/detail_card", label: t("mailers.labels.date"), value: @expense.formatted_date %>
    <%= render "shared/mailer/detail_card", label: t("mailers.labels.description"), value: @expense.description.presence || "-" %>
  </tr>
</table>

<div class="email-panel email-panel-warning">
  <p class="email-panel-title"><%= t("mailers.expense_mailer.rejected.next_step_title") %></p>
  <p style="margin-bottom: 0;"><%= t("mailers.expense_mailer.rejected.next_step_body") %></p>
</div>

<%= render "shared/mailer/button", href: @expense_url, label: t("mailers.actions.open_expense") %>
