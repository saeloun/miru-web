<!DOCTYPE html>
<html>
<head>
  <meta charset="utf-8">
  <title>Invoice</title>
  <link href="https://fonts.googleapis.com/css2?family=Inter:wght@400;500;600;700;800&family=Cormorant+Garamond:wght@500;600;700&display=swap" rel="stylesheet">
  <style>
    html {
      -webkit-print-color-adjust: exact;
    }

    body {
      margin: 0;
      padding: 0;
      background: #eef2f6;
      color: #0f172a;
      font-family: "Inter", -apple-system, BlinkMacSystemFont, "Segoe UI", sans-serif;
      font-size: 12px;
      line-height: 1.45;
    }

    .invoice-shell {
      padding: 16px;
    }

    .invoice-card {
      background: #ffffff;
      border: 1px solid #dbe3ec;
      border-radius: 22px;
      overflow: hidden;
      box-shadow: 0 16px 40px rgba(15, 23, 42, 0.08);
    }

    .invoice-hero {
      padding: 18px 28px 22px;
      background:
        linear-gradient(180deg, #fbfcfe 0%, #f8fafc 100%);
      border-bottom: 1px solid #e2e8f0;
      color: #0f172a;
      position: relative;
    }

    .invoice-hero::before {
      content: "";
      position: absolute;
      top: 0;
      left: 0;
      right: 0;
      height: 10px;
      background: linear-gradient(90deg, #111111 0%, #3f3f46 52%, #f3f4f6 100%);
    }

    .invoice-hero-row {
      width: 100%;
      border-collapse: collapse;
    }

    .invoice-brand {
      vertical-align: top;
    }

    .invoice-brand-wrap {
      display: table;
    }

    .invoice-logo-cell,
    .invoice-brand-copy {
      display: table-cell;
      vertical-align: top;
    }

    .invoice-logo-cell {
      width: 58px;
      padding-right: 14px;
    }

    .invoice-logo {
      display: block;
      width: 58px;
      height: 58px;
      object-fit: contain;
      border-radius: 16px;
      background: #ffffff;
      border: 1px solid #e2e8f0;
      padding: 6px;
      box-sizing: border-box;
    }

    .invoice-kicker {
      margin: 2px 0 8px;
      color: #64748b;
      font-size: 9px;
      font-weight: 700;
      letter-spacing: 0.22em;
      text-transform: uppercase;
    }

    .invoice-company {
      margin: 0;
      font-family: "Cormorant Garamond", Georgia, serif;
      font-size: 40px;
      font-weight: 700;
      line-height: 0.9;
      letter-spacing: -0.05em;
    }

    .invoice-company-meta {
      margin: 10px 0 0;
      color: #475569;
      font-size: 13px;
    }

    .invoice-status {
      width: 210px;
      vertical-align: top;
      text-align: right;
    }

    .invoice-status-pill {
      display: inline-block;
      padding: 7px 12px;
      border-radius: 999px;
      background: #eff3f8;
      border: 1px solid #d8e0ea;
      font-size: 9px;
      font-weight: 700;
      letter-spacing: 0.16em;
      text-transform: uppercase;
      color: #334155;
    }

    .invoice-status-amount {
      margin: 14px 0 0;
      font-family: "Cormorant Garamond", Georgia, serif;
      font-size: 58px;
      font-weight: 700;
      line-height: 0.88;
      letter-spacing: -0.04em;
    }

    .invoice-status-label {
      margin: 6px 0 0;
      color: #64748b;
      font-size: 9px;
      font-weight: 700;
      letter-spacing: 0.14em;
      text-transform: uppercase;
    }

    .invoice-body {
      padding: 18px 24px 22px;
    }

    .strip-grid {
      width: 100%;
      border-collapse: collapse;
      margin: 0 0 4px;
      border: 1px solid #e2e8f0;
      border-radius: 18px;
      overflow: hidden;
    }

    .strip-cell {
      width: 25%;
      vertical-align: top;
      border-right: 1px solid #e2e8f0;
    }

    .strip-cell:last-child {
      border-right: none;
    }

    .strip-label {
      margin: 0 0 6px;
      color: #64748b;
      font-size: 9px;
      font-weight: 700;
      letter-spacing: 0.14em;
      text-transform: uppercase;
    }

    .strip-card {
      height: 100%;
      padding: 12px 14px;
      background: linear-gradient(180deg, #ffffff 0%, #fbfcfe 100%);
    }

    .strip-value {
      margin: 0;
      color: #0f172a;
      font-size: 14px;
      font-weight: 700;
      line-height: 1.22;
      word-break: break-word;
    }

    .strip-subvalue {
      margin: 6px 0 0;
      color: #475569;
      font-size: 10px;
      line-height: 1.35;
      word-break: break-word;
    }

    .section {
      margin-top: 16px;
    }

    .section-title {
      margin: 0 0 10px;
      color: #64748b;
      font-size: 9px;
      font-weight: 800;
      letter-spacing: 0.2em;
      text-transform: uppercase;
    }

    .ledger-table {
      width: 100%;
      border-collapse: collapse;
      border-top: 1px solid #dbe3ec;
      border-bottom: 1px solid #dbe3ec;
    }

    .ledger-table thead th {
      padding: 9px 10px;
      background: #fbfcfd;
      color: #64748b;
      font-size: 9px;
      font-weight: 800;
      letter-spacing: 0.16em;
      text-transform: uppercase;
      text-align: left;
      border-bottom: 1px solid #e2e8f0;
    }

    .ledger-table tbody td {
      padding: 10px 10px;
      border-bottom: 1px solid #e2e8f0;
      color: #0f172a;
      font-size: 12px;
      vertical-align: top;
      word-break: break-word;
    }

    .ledger-table tbody tr:last-child td {
      border-bottom: none;
    }

    .text-right {
      text-align: right;
    }

    .line-name {
      font-weight: 700;
    }

    .line-description {
      color: #475569;
    }

    .summary-grid {
      width: 100%;
      margin-top: 18px;
      border-collapse: separate;
      border-spacing: 16px 0;
    }

    .summary-cell {
      width: 50%;
      vertical-align: top;
    }

    .summary-card {
      height: 100%;
      border-top: 2px solid #dbe3ec;
      background: transparent;
      page-break-inside: avoid;
    }

    .totals-panel {
      width: 100%;
      border-collapse: collapse;
    }

    .totals-panel td {
      padding: 9px 0;
      font-size: 13px;
      border-bottom: 1px solid #e2e8f0;
    }

    .totals-panel tr:last-child td {
      border-bottom: none;
    }

    .totals-label {
      color: #475569;
      text-align: right;
      padding-right: 14px !important;
    }

    .totals-value {
      color: #0f172a;
      font-weight: 700;
      text-align: right;
      white-space: nowrap;
    }

    .totals-grand td {
      background: #0f172a;
      color: #f8fafc;
      font-size: 14px;
      font-weight: 700;
      padding: 12px 14px;
    }

    .totals-grand .totals-label,
    .totals-grand .totals-value {
      color: #f8fafc;
    }

    .meta-panel {
      padding: 14px 0 0;
      page-break-inside: avoid;
    }

    .meta-grid {
      width: 100%;
      border-collapse: separate;
      border-spacing: 0 8px;
    }

    .meta-label {
      width: 118px;
      color: #64748b;
      font-size: 10px;
      font-weight: 700;
      letter-spacing: 0.12em;
      text-transform: uppercase;
      vertical-align: top;
    }

    .meta-value {
      color: #0f172a;
      font-size: 12px;
      vertical-align: top;
      word-break: break-word;
    }

    .editorial-note {
      margin: 12px 0 0;
      color: #64748b;
      font-size: 10px;
      line-height: 1.5;
    }
  </style>
</head>
<body>
  <%
    reference = invoice.reference.presence || "-"
    billed_to = client.formatted_address.presence || client.email.presence || "-"
    payment_rows = [
      ["Bank Name", invoice.company.bank_name],
      ["Account Number", invoice.company.bank_account_number],
      ["Routing Number", invoice.company.bank_routing_number],
      ["SWIFT Code", invoice.company.bank_swift_code],
      ["Tax ID", invoice.company.tax_id],
      ["VAT Number", invoice.company.vat_number],
      ["GST Number", invoice.company.gst_number]
    ].select { |_, value| value.present? }
  %>

  <div class="invoice-shell">
    <div class="invoice-card">
      <div class="invoice-hero">
        <table class="invoice-hero-row" role="presentation">
          <tr>
            <td class="invoice-brand">
              <div class="invoice-brand-wrap">
                <% if company_logo.present? %>
                  <div class="invoice-logo-cell">
                    <%= image_tag company_logo, class: "invoice-logo" %>
                  </div>
                <% end %>
                <div class="invoice-brand-copy">
                  <p class="invoice-kicker">Client Invoice</p>
                  <p class="invoice-company"><%= invoice.company.name %></p>
                  <p class="invoice-company-meta">
                    <%= invoice.company.business_phone.presence || invoice.company.email.presence || invoice.company.formatted_address %>
                  </p>
                </div>
              </div>
            </td>
            <td class="invoice-status">
              <span class="invoice-status-pill"><%= invoice.status.humanize %></span>
              <p class="invoice-status-amount"><%= invoice_amount %></p>
              <p class="invoice-status-label">Total invoice amount</p>
            </td>
          </tr>
        </table>
      </div>

      <div class="invoice-body">
        <table class="strip-grid" role="presentation">
          <tr>
            <td class="strip-cell">
              <div class="strip-card">
                <p class="strip-label">Billed To</p>
                <p class="strip-value"><%= client.name %></p>
                <p class="strip-subvalue"><%= billed_to %></p>
              </div>
            </td>
            <td class="strip-cell">
              <div class="strip-card">
                <p class="strip-label">Invoice Number</p>
                <p class="strip-value"><%= invoice.invoice_number %></p>
                <p class="strip-subvalue">Reference: <%= reference %></p>
              </div>
            </td>
            <td class="strip-cell">
              <div class="strip-card">
                <p class="strip-label">Issue Date</p>
                <p class="strip-value"><%= invoice.formatted_issue_date %></p>
                <p class="strip-subvalue">Due: <%= invoice.formatted_due_date %></p>
              </div>
            </td>
            <td class="strip-cell">
              <div class="strip-card">
                <p class="strip-label">Amount Due</p>
                <p class="strip-value"><%= invoice_amount_due %></p>
                <p class="strip-subvalue">Paid: <%= invoice_amount_paid %></p>
              </div>
            </td>
          </tr>
        </table>

        <div class="section">
          <p class="section-title">Work Summary</p>
          <table class="ledger-table" role="presentation">
            <thead>
              <tr>
                <th style="width: 16%;">Name</th>
                <th style="width: 12%;">Date</th>
                <th style="width: 32%;">Description</th>
                <th class="text-right" style="width: 13%;">Rate</th>
                <th class="text-right" style="width: 10%;">Qty</th>
                <th class="text-right" style="width: 17%;">Line Total</th>
              </tr>
            </thead>
            <tbody>
              <% invoice_line_items.each do |item| %>
                <tr>
                  <td class="line-name"><%= item[:name] %></td>
                  <td><%= item[:date] %></td>
                  <td class="line-description"><%= item[:description] %></td>
                  <td class="text-right"><%= item[:rate] %></td>
                  <td class="text-right"><%= item[:quantity] %></td>
                  <td class="text-right"><%= item[:line_total] %></td>
                </tr>
              <% end %>
            </tbody>
          </table>
          <p class="editorial-note">
            Prepared by <%= invoice.company.name %>, issued <%= invoice.formatted_issue_date %>, due <%= invoice.formatted_due_date %>.
          </p>
        </div>

        <table class="summary-grid" role="presentation">
          <tr>
            <td class="summary-cell">
              <% if payment_rows.any? %>
                <div class="summary-card meta-panel">
                  <p class="section-title" style="margin-top: 0;">Payment Details</p>
                  <table class="meta-grid" role="presentation">
                    <% payment_rows.each do |label, value| %>
                      <tr>
                        <td class="meta-label"><%= label %></td>
                        <td class="meta-value"><%= value %></td>
                      </tr>
                    <% end %>
                  </table>
                </div>
              <% end %>
            </td>
            <td class="summary-cell">
              <div class="summary-card">
              <table class="totals-panel" role="presentation">
                <tr>
                  <td class="totals-label">Sub total</td>
                  <td class="totals-value"><%= sub_total %></td>
                </tr>
                <tr>
                  <td class="totals-label">Discount</td>
                  <td class="totals-value"><%= invoice_discount %></td>
                </tr>
                <tr>
                  <td class="totals-label">Tax</td>
                  <td class="totals-value"><%= invoice_tax %></td>
                </tr>
                <tr class="totals-grand">
                  <td>Total</td>
                  <td class="totals-value"><%= total %></td>
                </tr>
                <tr>
                  <td class="totals-label">Amount Paid</td>
                  <td class="totals-value"><%= invoice_amount_paid %></td>
                </tr>
                <tr>
                  <td class="totals-label">Amount Due</td>
                  <td class="totals-value"><%= invoice_amount_due %></td>
                </tr>
              </table>
              </div>
            </td>
          </tr>
        </table>
      </div>
    </div>
  </div>
</body>
</html>
