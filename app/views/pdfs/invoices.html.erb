<!DOCTYPE html>
<html>
<head>
  <meta charset="utf-8">
  <title>Invoice</title>
  <link href="https://fonts.googleapis.com/css2?family=Inter:wght@400;500;600;700;800&display=swap" rel="stylesheet">
  <style>
    html {
      -webkit-print-color-adjust: exact;
    }

    body {
      margin: 0;
      padding: 0;
      background: #eef2f6;
      color: #0f172a;
      font-family: "Inter", -apple-system, BlinkMacSystemFont, "Segoe UI", sans-serif;
      font-size: 13px;
      line-height: 1.55;
    }

    .invoice-shell {
      padding: 20px;
    }

    .invoice-card {
      background: #ffffff;
      border: 1px solid #dbe3ec;
      border-radius: 28px;
      overflow: hidden;
      box-shadow: 0 16px 40px rgba(15, 23, 42, 0.08);
    }

    .invoice-hero {
      padding: 28px 32px 30px;
      background:
        linear-gradient(135deg, #0f172a 0%, #1e293b 58%, #334155 100%);
      color: #f8fafc;
    }

    .invoice-hero-row {
      width: 100%;
      border-collapse: collapse;
    }

    .invoice-brand {
      vertical-align: top;
    }

    .invoice-brand-wrap {
      display: table;
    }

    .invoice-logo-cell,
    .invoice-brand-copy {
      display: table-cell;
      vertical-align: top;
    }

    .invoice-logo-cell {
      width: 72px;
      padding-right: 16px;
    }

    .invoice-logo {
      display: block;
      width: 72px;
      height: 72px;
      object-fit: contain;
      border-radius: 20px;
      background: rgba(255, 255, 255, 0.96);
      padding: 8px;
      box-sizing: border-box;
    }

    .invoice-kicker {
      margin: 0 0 10px;
      color: rgba(226, 232, 240, 0.86);
      font-size: 10px;
      font-weight: 700;
      letter-spacing: 0.24em;
      text-transform: uppercase;
    }

    .invoice-company {
      margin: 0;
      font-size: 32px;
      font-weight: 800;
      line-height: 0.96;
      letter-spacing: -0.05em;
    }

    .invoice-company-meta {
      margin: 12px 0 0;
      color: rgba(226, 232, 240, 0.92);
      font-size: 14px;
    }

    .invoice-status {
      width: 200px;
      vertical-align: top;
      text-align: right;
    }

    .invoice-status-pill {
      display: inline-block;
      padding: 9px 14px;
      border-radius: 999px;
      background: rgba(255, 255, 255, 0.14);
      border: 1px solid rgba(255, 255, 255, 0.18);
      font-size: 10px;
      font-weight: 700;
      letter-spacing: 0.18em;
      text-transform: uppercase;
      color: #f8fafc;
    }

    .invoice-status-amount {
      margin: 22px 0 0;
      font-size: 40px;
      font-weight: 800;
      line-height: 0.96;
      letter-spacing: -0.06em;
    }

    .invoice-status-label {
      margin: 10px 0 0;
      color: rgba(226, 232, 240, 0.88);
      font-size: 11px;
      font-weight: 700;
      letter-spacing: 0.16em;
      text-transform: uppercase;
    }

    .invoice-body {
      padding: 28px 32px 32px;
    }

    .strip-grid {
      width: 100%;
      border-collapse: separate;
      border-spacing: 12px;
      margin: -12px -12px 6px;
    }

    .strip-cell {
      width: 25%;
      vertical-align: top;
    }

    .strip-card {
      height: 100%;
      padding: 16px 18px;
      border: 1px solid #e2e8f0;
      border-radius: 20px;
      background: linear-gradient(180deg, #ffffff 0%, #f8fafc 100%);
    }

    .strip-label {
      margin: 0 0 8px;
      color: #64748b;
      font-size: 10px;
      font-weight: 700;
      letter-spacing: 0.16em;
      text-transform: uppercase;
    }

    .strip-value {
      margin: 0;
      color: #0f172a;
      font-size: 18px;
      font-weight: 700;
      line-height: 1.3;
      word-break: break-word;
    }

    .strip-subvalue {
      margin: 7px 0 0;
      color: #475569;
      font-size: 12px;
      line-height: 1.5;
      word-break: break-word;
    }

    .section {
      margin-top: 24px;
    }

    .section-title {
      margin: 0 0 12px;
      color: #64748b;
      font-size: 10px;
      font-weight: 800;
      letter-spacing: 0.22em;
      text-transform: uppercase;
    }

    .ledger-table {
      width: 100%;
      border-collapse: collapse;
      border: 1px solid #e2e8f0;
      border-radius: 22px;
      overflow: hidden;
    }

    .ledger-table thead th {
      padding: 14px 16px;
      background: #f8fafc;
      color: #64748b;
      font-size: 10px;
      font-weight: 800;
      letter-spacing: 0.18em;
      text-transform: uppercase;
      text-align: left;
      border-bottom: 1px solid #e2e8f0;
    }

    .ledger-table tbody td {
      padding: 16px;
      border-bottom: 1px solid #e2e8f0;
      color: #0f172a;
      font-size: 13px;
      vertical-align: top;
      word-break: break-word;
    }

    .ledger-table tbody tr:last-child td {
      border-bottom: none;
    }

    .text-right {
      text-align: right;
    }

    .line-name {
      font-weight: 700;
    }

    .line-description {
      color: #475569;
    }

    .totals-wrap {
      width: 100%;
      margin-top: 24px;
      border-collapse: collapse;
    }

    .totals-spacer {
      width: 48%;
    }

    .totals-panel-cell {
      width: 52%;
      vertical-align: top;
    }

    .totals-panel {
      width: 100%;
      border: 1px solid #dbe3ec;
      border-radius: 24px;
      background: linear-gradient(180deg, #fbfdff 0%, #f8fafc 100%);
    }

    .totals-panel td {
      padding: 14px 22px;
      font-size: 14px;
      border-bottom: 1px solid #e2e8f0;
    }

    .totals-panel tr:last-child td {
      border-bottom: none;
    }

    .totals-label {
      color: #475569;
    }

    .totals-value {
      color: #0f172a;
      font-weight: 700;
      text-align: right;
      white-space: nowrap;
    }

    .totals-grand td {
      background: #0f172a;
      color: #f8fafc;
      font-size: 15px;
      font-weight: 700;
    }

    .meta-panel {
      margin-top: 24px;
      padding: 18px 20px;
      border: 1px solid #e2e8f0;
      border-radius: 22px;
      background: linear-gradient(180deg, #ffffff 0%, #f8fafc 100%);
    }

    .meta-grid {
      width: 100%;
      border-collapse: separate;
      border-spacing: 0 10px;
    }

    .meta-label {
      width: 180px;
      color: #64748b;
      font-size: 11px;
      font-weight: 700;
      letter-spacing: 0.12em;
      text-transform: uppercase;
      vertical-align: top;
    }

    .meta-value {
      color: #0f172a;
      font-size: 13px;
      vertical-align: top;
      word-break: break-word;
    }
  </style>
</head>
<body>
  <%
    reference = invoice.reference.presence || "-"
    billed_to = client.formatted_address.presence || client.email.presence || "-"
    payment_rows = [
      ["Bank Name", invoice.company.bank_name],
      ["Account Number", invoice.company.bank_account_number],
      ["Routing Number", invoice.company.bank_routing_number],
      ["SWIFT Code", invoice.company.bank_swift_code],
      ["Tax ID", invoice.company.tax_id],
      ["VAT Number", invoice.company.vat_number],
      ["GST Number", invoice.company.gst_number]
    ].select { |_, value| value.present? }
  %>

  <div class="invoice-shell">
    <div class="invoice-card">
      <div class="invoice-hero">
        <table class="invoice-hero-row" role="presentation">
          <tr>
            <td class="invoice-brand">
              <div class="invoice-brand-wrap">
                <% if company_logo.present? %>
                  <div class="invoice-logo-cell">
                    <%= image_tag company_logo, class: "invoice-logo" %>
                  </div>
                <% end %>
                <div class="invoice-brand-copy">
                  <p class="invoice-kicker">Client Invoice</p>
                  <p class="invoice-company"><%= invoice.company.name %></p>
                  <p class="invoice-company-meta">
                    <%= invoice.company.business_phone.presence || invoice.company.email.presence || invoice.company.formatted_address %>
                  </p>
                </div>
              </div>
            </td>
            <td class="invoice-status">
              <span class="invoice-status-pill"><%= invoice.status.humanize %></span>
              <p class="invoice-status-amount"><%= invoice_amount %></p>
              <p class="invoice-status-label">Total invoice amount</p>
            </td>
          </tr>
        </table>
      </div>

      <div class="invoice-body">
        <table class="strip-grid" role="presentation">
          <tr>
            <td class="strip-cell">
              <div class="strip-card">
                <p class="strip-label">Billed To</p>
                <p class="strip-value"><%= client.name %></p>
                <p class="strip-subvalue"><%= billed_to %></p>
              </div>
            </td>
            <td class="strip-cell">
              <div class="strip-card">
                <p class="strip-label">Invoice Number</p>
                <p class="strip-value"><%= invoice.invoice_number %></p>
                <p class="strip-subvalue">Reference: <%= reference %></p>
              </div>
            </td>
            <td class="strip-cell">
              <div class="strip-card">
                <p class="strip-label">Issue Date</p>
                <p class="strip-value"><%= invoice.formatted_issue_date %></p>
                <p class="strip-subvalue">Due: <%= invoice.formatted_due_date %></p>
              </div>
            </td>
            <td class="strip-cell">
              <div class="strip-card">
                <p class="strip-label">Amount Due</p>
                <p class="strip-value"><%= invoice_amount_due %></p>
                <p class="strip-subvalue">Paid: <%= invoice_amount_paid %></p>
              </div>
            </td>
          </tr>
        </table>

        <div class="section">
          <p class="section-title">Work Summary</p>
          <table class="ledger-table" role="presentation">
            <thead>
              <tr>
                <th style="width: 16%;">Name</th>
                <th style="width: 12%;">Date</th>
                <th style="width: 32%;">Description</th>
                <th class="text-right" style="width: 13%;">Rate</th>
                <th class="text-right" style="width: 10%;">Qty</th>
                <th class="text-right" style="width: 17%;">Line Total</th>
              </tr>
            </thead>
            <tbody>
              <% invoice_line_items.each do |item| %>
                <tr>
                  <td class="line-name"><%= item[:name] %></td>
                  <td><%= item[:date] %></td>
                  <td class="line-description"><%= item[:description] %></td>
                  <td class="text-right"><%= item[:rate] %></td>
                  <td class="text-right"><%= item[:quantity] %></td>
                  <td class="text-right"><%= item[:line_total] %></td>
                </tr>
              <% end %>
            </tbody>
          </table>
        </div>

        <table class="totals-wrap" role="presentation">
          <tr>
            <td class="totals-spacer"></td>
            <td class="totals-panel-cell">
              <table class="totals-panel" role="presentation">
                <tr>
                  <td class="totals-label">Sub total</td>
                  <td class="totals-value"><%= sub_total %></td>
                </tr>
                <tr>
                  <td class="totals-label">Discount</td>
                  <td class="totals-value"><%= invoice_discount %></td>
                </tr>
                <tr>
                  <td class="totals-label">Tax</td>
                  <td class="totals-value"><%= invoice_tax %></td>
                </tr>
                <tr class="totals-grand">
                  <td>Total</td>
                  <td class="totals-value"><%= total %></td>
                </tr>
                <tr>
                  <td class="totals-label">Amount Paid</td>
                  <td class="totals-value"><%= invoice_amount_paid %></td>
                </tr>
                <tr>
                  <td class="totals-label">Amount Due</td>
                  <td class="totals-value"><%= invoice_amount_due %></td>
                </tr>
              </table>
            </td>
          </tr>
        </table>

        <% if payment_rows.any? %>
          <div class="meta-panel">
            <p class="section-title" style="margin-top: 0;">Payment Details</p>
            <table class="meta-grid" role="presentation">
              <% payment_rows.each do |label, value| %>
                <tr>
                  <td class="meta-label"><%= label %></td>
                  <td class="meta-value"><%= value %></td>
                </tr>
              <% end %>
            </table>
          </div>
        <% end %>
      </div>
    </div>
  </div>
</body>
</html>
