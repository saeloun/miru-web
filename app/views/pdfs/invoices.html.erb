<!DOCTYPE html>
<html>
<head>
  <meta charset="utf-8">
  <title><%= t("pdfs.invoices.title") %></title>
  <style>
    html {
      -webkit-print-color-adjust: exact;
    }

    body {
      margin: 0;
      padding: 0;
      background: #eef2f6;
      color: #0f172a;
      font-family: -apple-system, BlinkMacSystemFont, "Segoe UI", "Helvetica Neue", Arial, sans-serif;
      font-size: 12px;
      line-height: 1.45;
    }

    .invoice-shell {
      padding: 16px;
    }

    .invoice-card {
      background: #ffffff;
      border: 1px solid #dbe3ec;
      border-radius: 22px;
      overflow: hidden;
      box-shadow: 0 16px 40px rgba(15, 23, 42, 0.08);
    }

    .invoice-hero {
      padding: 18px 28px 22px;
      background:
        linear-gradient(180deg, #fbfcfe 0%, #f8fafc 100%);
      border-bottom: 1px solid #e2e8f0;
      color: #0f172a;
      position: relative;
    }

    .invoice-hero::before {
      content: "";
      position: absolute;
      top: 0;
      left: 0;
      right: 0;
      height: 10px;
      background: linear-gradient(90deg, #111111 0%, #3f3f46 52%, #f3f4f6 100%);
    }

    .invoice-hero-row {
      width: 100%;
      border-collapse: collapse;
    }

    .invoice-brand {
      vertical-align: top;
    }

    .invoice-brand-wrap {
      display: table;
    }

    .invoice-logo-cell,
    .invoice-brand-copy {
      display: table-cell;
      vertical-align: top;
    }

    .invoice-logo-cell {
      width: 58px;
      padding-right: 14px;
    }

    .invoice-logo {
      display: block;
      width: 58px;
      height: 58px;
      object-fit: contain;
      border-radius: 16px;
      background: #ffffff;
      border: 1px solid #e2e8f0;
      padding: 6px;
      box-sizing: border-box;
    }

    .invoice-kicker {
      margin: 2px 0 8px;
      color: #64748b;
      font-size: 9px;
      font-weight: 700;
      letter-spacing: 0.22em;
      text-transform: uppercase;
    }

    .invoice-company {
      margin: 0;
      font-family: Georgia, "Times New Roman", serif;
      font-size: 40px;
      font-weight: 700;
      line-height: 0.9;
      letter-spacing: -0.05em;
    }

    .invoice-company-meta {
      margin: 10px 0 0;
      color: #475569;
      font-size: 13px;
    }

    .invoice-status {
      width: 210px;
      vertical-align: top;
      text-align: right;
    }

    .invoice-status-pill {
      display: inline-block;
      padding: 7px 12px;
      border-radius: 999px;
      background: #eff3f8;
      border: 1px solid #d8e0ea;
      font-size: 9px;
      font-weight: 700;
      letter-spacing: 0.16em;
      text-transform: uppercase;
      color: #334155;
    }

    .invoice-status-amount {
      margin: 14px 0 0;
      font-family: "Cormorant Garamond", Georgia, serif;
      font-size: 58px;
      font-weight: 700;
      line-height: 0.88;
      letter-spacing: -0.04em;
    }

    .invoice-status-label {
      margin: 6px 0 0;
      color: #64748b;
      font-size: 9px;
      font-weight: 700;
      letter-spacing: 0.14em;
      text-transform: uppercase;
    }

    .invoice-body {
      padding: 18px 24px 22px;
    }

    .strip-grid {
      width: 100%;
      border-collapse: collapse;
      margin: 0 0 4px;
      border: 1px solid #e2e8f0;
      border-radius: 18px;
      overflow: hidden;
    }

    .strip-cell {
      width: 25%;
      vertical-align: top;
      border-right: 1px solid #e2e8f0;
    }

    .strip-cell:last-child {
      border-right: none;
    }

    .strip-label {
      margin: 0 0 6px;
      color: #64748b;
      font-size: 9px;
      font-weight: 700;
      letter-spacing: 0.14em;
      text-transform: uppercase;
    }

    .strip-card {
      height: 100%;
      padding: 12px 14px;
      background: linear-gradient(180deg, #ffffff 0%, #fbfcfe 100%);
    }

    .strip-value {
      margin: 0;
      color: #0f172a;
      font-size: 14px;
      font-weight: 700;
      line-height: 1.22;
      word-break: break-word;
    }

    .strip-subvalue {
      margin: 6px 0 0;
      color: #475569;
      font-size: 10px;
      line-height: 1.35;
      word-break: break-word;
    }

    .section {
      margin-top: 16px;
    }

    .section-title {
      margin: 0 0 10px;
      color: #64748b;
      font-size: 9px;
      font-weight: 800;
      letter-spacing: 0.2em;
      text-transform: uppercase;
    }

    .ledger-table {
      width: 100%;
      border-collapse: collapse;
      border-top: 1px solid #dbe3ec;
      border-bottom: 1px solid #dbe3ec;
    }

    .ledger-table thead th {
      padding: 9px 10px;
      background: #fbfcfd;
      color: #64748b;
      font-size: 9px;
      font-weight: 800;
      letter-spacing: 0.16em;
      text-transform: uppercase;
      text-align: left;
      border-bottom: 1px solid #e2e8f0;
    }

    .ledger-table tbody td {
      padding: 10px 10px;
      border-bottom: 1px solid #e2e8f0;
      color: #0f172a;
      font-size: 12px;
      vertical-align: top;
      word-break: break-word;
    }

    .ledger-table tbody tr:last-child td {
      border-bottom: none;
    }

    .text-right {
      text-align: right;
    }

    .line-name {
      font-weight: 700;
    }

    .line-description {
      color: #475569;
    }

    .summary-grid {
      width: 100%;
      margin-top: 18px;
      border-collapse: separate;
      border-spacing: 16px 0;
    }

    .summary-cell {
      width: 50%;
      vertical-align: top;
    }

    .summary-card {
      height: 100%;
      border-top: 2px solid #dbe3ec;
      background: transparent;
      page-break-inside: avoid;
    }

    .totals-panel {
      width: 100%;
      border-collapse: collapse;
    }

    .totals-panel td {
      padding: 9px 0;
      font-size: 13px;
      border-bottom: 1px solid #e2e8f0;
    }

    .totals-panel tr:last-child td {
      border-bottom: none;
    }

    .totals-label {
      color: #475569;
      text-align: right;
      padding-right: 14px !important;
    }

    .totals-value {
      color: #0f172a;
      font-weight: 700;
      text-align: right;
      white-space: nowrap;
    }

    .totals-grand td {
      background: #0f172a;
      color: #f8fafc;
      font-size: 14px;
      font-weight: 700;
      padding: 12px 14px;
    }

    .totals-grand .totals-label,
    .totals-grand .totals-value {
      color: #f8fafc;
    }

    .meta-panel {
      padding: 14px 0 0;
      page-break-inside: avoid;
    }

    .meta-grid {
      width: 100%;
      border-collapse: separate;
      border-spacing: 0 8px;
    }

    .meta-label {
      width: 118px;
      color: #64748b;
      font-size: 10px;
      font-weight: 700;
      letter-spacing: 0.12em;
      text-transform: uppercase;
      vertical-align: top;
    }

    .meta-value {
      color: #0f172a;
      font-size: 12px;
      vertical-align: top;
      word-break: break-word;
    }

    .editorial-note {
      margin: 12px 0 0;
      color: #64748b;
      font-size: 10px;
      line-height: 1.5;
    }
  </style>
</head>
<body>
  <%
    reference = invoice.reference.presence || "-"
    billed_to = client.formatted_address.presence || client.email.presence || "-"
    payment_rows = [
      [t("pdfs.invoices.payment_rows.bank_name"), invoice.company.bank_name],
      [t("pdfs.invoices.payment_rows.account_number"), invoice.company.bank_account_number],
      [t("pdfs.invoices.payment_rows.routing_number"), invoice.company.bank_routing_number],
      [t("pdfs.invoices.payment_rows.swift_code"), invoice.company.bank_swift_code],
      [t("pdfs.invoices.payment_rows.tax_id"), invoice.company.tax_id],
      [t("pdfs.invoices.payment_rows.vat_number"), invoice.company.vat_number],
      [t("pdfs.invoices.payment_rows.gst_number"), invoice.company.gst_number]
    ].select { |_, value| value.present? }
  %>

  <div class="invoice-shell">
    <div class="invoice-card">
      <div class="invoice-hero">
        <table class="invoice-hero-row" role="presentation">
          <tr>
            <td class="invoice-brand">
              <div class="invoice-brand-wrap">
                <% if company_logo.present? %>
                  <div class="invoice-logo-cell">
                    <%= image_tag company_logo, class: "invoice-logo" %>
                  </div>
                <% end %>
                <div class="invoice-brand-copy">
                  <p class="invoice-kicker"><%= t("pdfs.invoices.client_invoice") %></p>
                  <p class="invoice-company"><%= invoice.company.name %></p>
                  <p class="invoice-company-meta">
                    <%= invoice.company.business_phone.presence || invoice.company.email.presence || invoice.company.formatted_address %>
                  </p>
                </div>
              </div>
            </td>
            <td class="invoice-status">
              <span class="invoice-status-pill"><%= invoice.status.humanize %></span>
              <p class="invoice-status-amount"><%= invoice_amount %></p>
              <p class="invoice-status-label"><%= t("pdfs.invoices.total_invoice_amount") %></p>
            </td>
          </tr>
        </table>
      </div>

      <div class="invoice-body">
        <table class="strip-grid" role="presentation">
          <tr>
            <td class="strip-cell">
              <div class="strip-card">
                <p class="strip-label"><%= t("pdfs.invoices.billed_to") %></p>
                <p class="strip-value"><%= client.name %></p>
                <p class="strip-subvalue"><%= billed_to %></p>
              </div>
            </td>
            <td class="strip-cell">
              <div class="strip-card">
                <p class="strip-label"><%= t("pdfs.invoices.invoice_number") %></p>
                <p class="strip-value"><%= invoice.invoice_number %></p>
                <p class="strip-subvalue"><%= t("pdfs.invoices.reference", reference: reference) %></p>
              </div>
            </td>
            <td class="strip-cell">
              <div class="strip-card">
                <p class="strip-label"><%= t("pdfs.invoices.issue_date") %></p>
                <p class="strip-value"><%= invoice.formatted_issue_date %></p>
                <p class="strip-subvalue"><%= t("pdfs.invoices.due", due_date: invoice.formatted_due_date) %></p>
              </div>
            </td>
            <td class="strip-cell">
              <div class="strip-card">
                <p class="strip-label"><%= t("pdfs.invoices.amount_due") %></p>
                <p class="strip-value"><%= invoice_amount_due %></p>
                <p class="strip-subvalue"><%= t("pdfs.invoices.paid", amount: invoice_amount_paid) %></p>
              </div>
            </td>
          </tr>
        </table>

        <div class="section">
          <p class="section-title"><%= t("pdfs.invoices.work_summary") %></p>
          <table class="ledger-table" role="presentation">
            <thead>
              <tr>
                <th style="width: 16%;"><%= t("pdfs.invoices.table.name") %></th>
                <th style="width: 12%;"><%= t("pdfs.invoices.table.date") %></th>
                <th style="width: 32%;"><%= t("pdfs.invoices.table.description") %></th>
                <th class="text-right" style="width: 13%;"><%= t("pdfs.invoices.table.rate") %></th>
                <th class="text-right" style="width: 10%;"><%= t("pdfs.invoices.table.qty") %></th>
                <th class="text-right" style="width: 17%;"><%= t("pdfs.invoices.table.line_total") %></th>
              </tr>
            </thead>
            <tbody>
              <% invoice_line_items.each do |item| %>
                <tr>
                  <td class="line-name"><%= item[:name] %></td>
                  <td><%= item[:date] %></td>
                  <td class="line-description"><%= item[:description] %></td>
                  <td class="text-right"><%= item[:rate] %></td>
                  <td class="text-right"><%= item[:quantity] %></td>
                  <td class="text-right"><%= item[:line_total] %></td>
                </tr>
              <% end %>
            </tbody>
          </table>
          <p class="editorial-note">
            <%= t("pdfs.invoices.prepared_by", company_name: invoice.company.name, issue_date: invoice.formatted_issue_date, due_date: invoice.formatted_due_date) %>
          </p>
        </div>

        <table class="summary-grid" role="presentation">
          <tr>
            <td class="summary-cell">
              <% if payment_rows.any? %>
                <div class="summary-card meta-panel">
                  <p class="section-title" style="margin-top: 0;"><%= t("pdfs.invoices.payment_details") %></p>
                  <table class="meta-grid" role="presentation">
                    <% payment_rows.each do |label, value| %>
                      <tr>
                        <td class="meta-label"><%= label %></td>
                        <td class="meta-value"><%= value %></td>
                      </tr>
                    <% end %>
                  </table>
                </div>
              <% end %>
            </td>
            <td class="summary-cell">
              <div class="summary-card">
              <table class="totals-panel" role="presentation">
                <tr>
                  <td class="totals-label"><%= t("pdfs.invoices.sub_total") %></td>
                  <td class="totals-value"><%= sub_total %></td>
                </tr>
                <tr>
                  <td class="totals-label"><%= t("pdfs.invoices.discount") %></td>
                  <td class="totals-value"><%= invoice_discount %></td>
                </tr>
                <tr>
                  <td class="totals-label"><%= t("pdfs.invoices.tax") %></td>
                  <td class="totals-value"><%= invoice_tax %></td>
                </tr>
                <tr class="totals-grand">
                  <td><%= t("pdfs.invoices.total") %></td>
                  <td class="totals-value"><%= total %></td>
                </tr>
                <tr>
                  <td class="totals-label"><%= t("pdfs.invoices.amount_paid") %></td>
                  <td class="totals-value"><%= invoice_amount_paid %></td>
                </tr>
                <tr>
                  <td class="totals-label"><%= t("pdfs.invoices.amount_due") %></td>
                  <td class="totals-value"><%= invoice_amount_due %></td>
                </tr>
              </table>
              </div>
            </td>
          </tr>
        </table>
      </div>
    </div>
  </div>
</body>
</html>
