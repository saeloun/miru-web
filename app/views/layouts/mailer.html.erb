<!DOCTYPE html PUBLIC "-//W3C//DTD XHTML 1.0 Transitional//EN" "http://www.w3.org/TR/xhtml1/DTD/xhtml1-transitional.dtd">
<html xmlns="http://www.w3.org/1999/xhtml">
  <head>
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <meta name="x-apple-disable-message-reformatting" />
    <meta http-equiv="Content-Type" content="text/html; charset=UTF-8" />
    <meta name="color-scheme" content="light dark" />
    <meta name="supported-color-schemes" content="light dark" />
    <style>
      :root {
        color-scheme: light dark;
        supported-color-schemes: light dark;
      }

      body,
      table,
      td,
      a {
        -webkit-text-size-adjust: 100%;
        -ms-text-size-adjust: 100%;
      }

      table,
      td {
        mso-table-lspace: 0pt;
        mso-table-rspace: 0pt;
      }
      td {
        word-break: break-word;
      }

      img {
        -ms-interpolation-mode: bicubic;
        border: 0;
        outline: none;
        text-decoration: none;
      }

      body {
        margin: 0;
        padding: 0;
        width: 100% !important;
        min-width: 100%;
        background-color: #f5f7fb;
        color: #020617;
        font-family: Inter, "Segoe UI", "Helvetica Neue", Arial, sans-serif;
      }

      a {
        color: #0f172a;
      }

      .email-shell {
        width: 100%;
        background-color: #f5f7fb;
        padding: 44px 16px;
      }

      .email-card {
        width: 100%;
        max-width: 640px;
        background-color: #ffffff;
        border: 1px solid #e5e7eb;
        border-radius: 8px;
        overflow: hidden;
      }

      .email-card-inner {
        padding: 40px 44px 42px;
      }

      .email-brand {
        padding: 34px 44px 26px;
        text-align: center;
        background-color: #ffffff;
        border-bottom: 1px solid #e5e7eb;
      }

      .email-brand-logo {
        display: block;
        width: 120px;
        height: auto;
        margin: 0 auto;
      }

      .email-company-logo {
        display: block;
        width: 72px;
        height: 72px;
        object-fit: cover;
        border-radius: 12px;
        margin: 0 auto;
      }

      .email-brand-logo-wrap {
        display: inline-block;
        width: 72px;
        height: 72px;
        border-radius: 12px;
        border: 1px solid #e5e7eb;
        background-color: #f8fafc;
        overflow: hidden;
        line-height: 0;
        font-size: 0;
      }

      .email-eyebrow {
        margin: 20px 0 0;
        color: #64748b;
        font-size: 10px;
        font-weight: 700;
        letter-spacing: 0.22em;
        text-transform: uppercase;
      }

      .email-title {
        margin: 12px 0 0;
        color: #020617;
        font-size: 28px;
        font-weight: 700;
        line-height: 1.25;
        letter-spacing: 0;
        max-width: 520px;
        margin-left: auto;
        margin-right: auto;
      }

      .email-subtitle {
        margin: 16px auto 0;
        max-width: 560px;
        color: #475569;
        font-size: 15px;
        line-height: 1.78;
        overflow-wrap: anywhere;
        word-break: break-word;
      }

      .email-body {
        color: #334155;
        font-size: 15px;
        line-height: 1.8;
        overflow-wrap: anywhere;
        word-break: break-word;
      }

      .email-body p {
        margin: 0 0 16px;
      }

      .email-body strong {
        color: #0f172a;
      }

      .email-highlight {
        margin: 24px 0;
        padding: 26px 24px;
        border: 1px solid #e7ebf0;
        border-radius: 8px;
        background-color: #f8fafc;
        text-align: center;
      }

      .email-highlight-label {
        margin: 0 0 10px;
        color: #5b6b7f;
        font-size: 11px;
        font-weight: 700;
        letter-spacing: 0.14em;
        text-transform: uppercase;
      }

      .email-highlight-value {
        margin: 0;
        color: #020617;
        font-size: 34px;
        font-weight: 700;
        line-height: 1.08;
        letter-spacing: 0;
      }

      .email-highlight-caption {
        margin: 12px 0 0;
        color: #475569;
        font-size: 14px;
        line-height: 1.65;
      }

      .email-list {
        margin: 0;
        padding-left: 20px;
      }

      .email-list li {
        margin: 0 0 10px;
      }

      .email-panel {
        margin: 24px 0;
        padding: 20px 22px;
        border-radius: 8px;
        border: 1px solid #e6ebf1;
        background-color: #ffffff;
      }

      .email-panel-soft {
        background-color: #f8fafc;
      }

      .email-panel-accent {
        background-color: #f8fafc;
        border-color: #d5dde7;
      }

      .email-panel-success {
        border-color: rgba(22, 163, 74, 0.18);
        background-color: #f0fdf4;
      }

      .email-panel-warning {
        border-color: rgba(245, 158, 11, 0.24);
        background-color: #fffbeb;
      }

      .email-panel-danger {
        border-color: rgba(239, 68, 68, 0.24);
        background-color: #fef2f2;
      }

      .email-panel-title {
        margin: 0 0 10px;
        color: #020617;
        font-size: 16px;
        font-weight: 600;
        line-height: 1.45;
      }

      .email-muted {
        color: #64748b;
      }

      .email-button-wrap {
        margin: 30px 0 0;
      }

      .email-button-cell {
        width: auto;
      }

      .email-button {
        display: inline-block;
        padding: 0;
        border-radius: 4px;
        background: #0f172a;
        border: 12px solid #0f172a;
        border-left-width: 22px;
        border-right-width: 22px;
        color: #ffffff !important;
        font-size: 15px;
        font-weight: 700;
        line-height: 1.2;
        letter-spacing: 0;
        text-decoration: none;
        box-sizing: border-box;
      }

      .email-button-secondary {
        background: #ffffff;
        border-color: #d2d9e2;
        color: #0f172a !important;
      }

      .email-divider {
        height: 1px;
        margin: 26px 0;
        background-color: #e2e8f0;
      }

      .detail-grid {
        width: 100%;
      }

      .detail-cell {
        width: 50%;
        padding: 0 8px 16px;
        vertical-align: top;
      }

      .detail-card {
        width: 100%;
        border: 1px solid #e7ebf0;
        border-radius: 8px;
        background-color: #ffffff;
      }

      .detail-card td {
        padding: 18px 20px;
      }

      .detail-label {
        margin: 0 0 8px;
        color: #64748b;
        font-size: 11px;
        font-weight: 700;
        letter-spacing: 0.12em;
        text-transform: uppercase;
      }

      .detail-value {
        margin: 0;
        color: #0f172a;
        font-size: 18px;
        font-weight: 600;
        line-height: 1.45;
        overflow-wrap: anywhere;
        word-break: break-word;
      }

      .detail-subvalue {
        margin: 8px 0 0;
        color: #475569;
        font-size: 14px;
        line-height: 1.6;
        overflow-wrap: anywhere;
        word-break: break-word;
      }

      .email-fact-table {
        width: 100%;
        margin: 20px 0 0;
        border-collapse: collapse;
        border-top: 1px solid #e7ebf0;
        border-bottom: 1px solid #e7ebf0;
        background-color: #ffffff;
      }

      .email-fact-table td {
        padding: 15px 4px;
        border-bottom: 1px solid #e9edf2;
        vertical-align: top;
      }

      .email-fact-table tr:last-child td {
        border-bottom: 0;
      }

      .email-fact-key {
        color: #6b7280;
        font-size: 11px;
        line-height: 1.5;
        padding-right: 16px;
        text-transform: uppercase;
        letter-spacing: 0.08em;
      }

      .email-fact-value {
        color: #020617;
        font-size: 14px;
        font-weight: 600;
        line-height: 1.6;
        text-align: right;
        overflow-wrap: anywhere;
        word-break: break-word;
      }

      .email-footer {
        padding: 0 38px 34px;
      }

      .email-footer-card {
        border-radius: 8px;
        border: 1px solid #e6ebf1;
        background-color: #ffffff;
      }

      .email-footer-card td {
        padding: 16px 20px;
        color: #64748b;
        font-size: 12px;
        line-height: 1.7;
        text-align: center;
        overflow-wrap: anywhere;
        word-break: break-word;
      }

      .email-footer-link {
        color: #0f172a !important;
        text-decoration: none;
      }

      .digest-kicker {
        margin: 0 0 8px;
        color: #0f766e;
        font-size: 12px;
        font-weight: 600;
        text-transform: uppercase;
        letter-spacing: 0.12em;
      }

      .digest-value {
        margin: 0;
        color: #020617;
        font-size: 38px;
        font-weight: 700;
        line-height: 1.05;
        letter-spacing: 0;
      }

      .digest-caption {
        margin: 12px 0 0;
        color: #475569;
        font-size: 14px;
        line-height: 1.6;
      }

      .digest-trend-table {
        margin-top: 20px;
      }

      .digest-trend-cell {
        height: 88px;
        padding: 0 2px;
        vertical-align: bottom;
      }

      .digest-trend-bar {
        width: 100%;
        border-radius: 4px 4px 0 0;
        background-color: #0f172a;
      }

      .digest-trend-labels {
        margin-top: 8px;
        color: #64748b;
        font-size: 12px;
      }

      .digest-source-name {
        padding: 10px 0;
        color: #111827;
        font-size: 14px;
        line-height: 1.5;
        border-bottom: 1px solid #e2e8f0;
      }

      .digest-source-amount {
        padding: 10px 0 10px 16px;
        color: #047857;
        font-size: 14px;
        font-weight: 600;
        line-height: 1.5;
        border-bottom: 1px solid #e2e8f0;
        white-space: nowrap;
      }

      .digest-empty-state {
        color: #64748b;
        font-size: 14px;
        line-height: 1.6;
      }

      @media only screen and (max-width: 640px) {
        .email-shell {
          padding: 20px 8px !important;
        }

        .email-card {
          border-radius: 0 !important;
        }

        .email-brand {
          padding: 24px 22px 22px !important;
        }

        .email-card-inner {
          padding: 28px 20px !important;
        }

        .email-footer {
          padding: 0 20px 20px !important;
        }

        .email-title {
          font-size: 24px !important;
        }

        .email-company-logo {
          width: 72px !important;
          height: 72px !important;
        }

        .email-brand-logo-wrap {
          width: 72px !important;
          height: 72px !important;
        }

        .email-highlight {
          padding: 24px 18px !important;
        }

        .email-highlight-value {
          font-size: 28px !important;
        }

        .detail-cell,
        .stack-cell {
          display: block !important;
          width: 100% !important;
          padding-left: 0 !important;
          padding-right: 0 !important;
        }

        .email-fact-key,
        .email-fact-value {
          display: block !important;
          width: 100% !important;
          text-align: left !important;
          padding: 0 !important;
        }

        .email-fact-value {
          margin-top: 4px !important;
        }

        .email-button {
          display: block !important;
          width: 100% !important;
          box-sizing: border-box !important;
          text-align: center !important;
        }

        .email-button-wrap,
        .email-button-cell {
          width: 100% !important;
        }
      }

      @media (prefers-color-scheme: dark) {
        .logo-light-mode { display: none !important; }
        .logo-dark-mode { display: block !important; }

        body,
        .email-shell {
          background-color: #111827 !important;
          color: #f8fafc !important;
        }
        .email-card,
        .email-brand,
        .email-footer-card,
        .detail-card,
        .email-fact-table {
          background-color: #1f2937 !important;
          border-color: #374151 !important;
        }
        .email-body,
        .email-title,
        .email-subtitle,
        .email-highlight-value,
        .detail-value,
        .email-fact-value,
        .email-panel-title,
        .digest-value,
        a {
          color: #f8fafc !important;
        }
        .email-eyebrow,
        .email-muted,
        .email-highlight-caption,
        .detail-subvalue,
        .email-footer-card td,
        .email-fact-key {
          color: #cbd5e1 !important;
        }
        .email-highlight,
        .email-panel,
        .email-panel-soft {
          background-color: #111827 !important;
          border-color: #374151 !important;
        }
        .email-button {
          background-color: #f8fafc !important;
          border-color: #f8fafc !important;
          color: #111827 !important;
        }
        .email-button-secondary {
          background-color: #1f2937 !important;
          border-color: #64748b !important;
          color: #f8fafc !important;
        }
      }

    </style>
    <!--[if mso]>
    <style type="text/css">
      body, table, td, a, p, div {
        font-family: Arial, sans-serif !important;
      }
    </style>
    <![endif]-->
  </head>
  <body style="margin: 0; padding: 0; width: 100%; min-width: 100%; background-color: #f5f7fb; color: #020617; font-family: Inter, 'Segoe UI', 'Helvetica Neue', Arial, sans-serif;">
    <% preheader = content_for?(:email_preheader) ? yield(:email_preheader).to_s.strip : t("mailers.layout.preheader") %>
    <% brand_logo_url = email_company_logo_url %>
    <% brand_name = email_company_name %>
    <div style="display: none; max-height: 0; overflow: hidden; opacity: 0; mso-hide: all;">
      <%= preheader %>
    </div>
    <table role="presentation" width="100%" cellpadding="0" cellspacing="0" border="0" class="email-shell" style="width: 100%; margin: 0; padding: 44px 16px; background-color: #f5f7fb; border-collapse: collapse;">
      <tr>
        <td align="center" style="padding: 0;">
          <table role="presentation" width="100%" cellpadding="0" cellspacing="0" border="0" class="email-card" style="width: 100%; max-width: 640px; background-color: #ffffff; border: 1px solid #e5e7eb; border-radius: 8px; overflow: hidden;">
            <tr>
              <td class="email-brand" style="padding: 34px 44px 26px; text-align: center; background-color: #ffffff; border-bottom: 1px solid #e5e7eb;">
                <table role="presentation" cellpadding="0" cellspacing="0" border="0" align="center">
                  <tr>
                    <td align="center">
                      <% if content_for?(:email_badge) %>
                        <%= yield :email_badge %>
                      <% elsif brand_logo_url.present? %>
                        <div class="email-brand-logo-wrap" style="display: inline-block; width: 72px; height: 72px; border-radius: 12px; border: 1px solid #e5e7eb; background-color: #f8fafc; overflow: hidden; line-height: 0; font-size: 0;">
                          <img src="<%= brand_logo_url %>" width="72" height="72" alt="<%= brand_name %>" class="email-company-logo" style="display: block; width: 72px; height: 72px; object-fit: cover; border-radius: 12px; border: 0; outline: none; text-decoration: none;" />
                        </div>
                      <% elsif miru_logo_dark_url.present? %>
                        <img src="<%= miru_logo_dark_url %>" width="120" alt="<%= t("mailers.layout.brand") %>" class="email-brand-logo logo-light-mode" style="display: block; width: 120px; height: auto; margin: 0 auto; border: 0; outline: none; text-decoration: none;" />
                        <% if miru_logo_light_url.present? %>
                          <img src="<%= miru_logo_light_url %>" width="120" alt="<%= t("mailers.layout.brand") %>" class="email-brand-logo logo-dark-mode" style="display: none; width: 120px; height: auto; margin: 0 auto; border: 0; outline: none; text-decoration: none;" />
                        <% end %>
                        <div style="margin-top: 8px; color: #64748b; font-size: 9px; font-weight: 700; letter-spacing: 0.18em; line-height: 1.2;">TRACK. BILL. GET PAID.</div>
                      <% else %>
                        <table role="presentation" cellpadding="0" cellspacing="0" border="0" align="center" aria-label="<%= t("mailers.layout.brand") %>" style="margin: 0 auto; border-collapse: collapse;">
                          <tr>
                            <td style="width: 34px; height: 34px; border-radius: 8px; background-color: #020617; color: #ffffff; font-size: 18px; font-weight: 800; line-height: 34px; text-align: center;">M</td>
                            <td style="padding-left: 10px; text-align: left;">
                              <div style="color: #020617; font-size: 22px; font-weight: 800; line-height: 1;">Miru</div>
                              <div style="margin-top: 4px; color: #64748b; font-size: 9px; font-weight: 700; letter-spacing: 0.18em; line-height: 1.2;">TRACK. BILL. GET PAID.</div>
                            </td>
                          </tr>
                        </table>
                      <% end %>
                    </td>
                  </tr>
                </table>
                <% if content_for?(:email_eyebrow) %>
                  <p class="email-eyebrow"><%= yield :email_eyebrow %></p>
                <% end %>
                <% if content_for?(:email_title) %>
                  <h1 class="email-title"><%= yield :email_title %></h1>
                <% end %>
                <% if content_for?(:email_subtitle) %>
                  <div class="email-subtitle"><%= yield :email_subtitle %></div>
                <% end %>
              </td>
            </tr>
            <tr>
              <td class="email-card-inner email-body">
                <%= yield %>
              </td>
            </tr>
            <tr>
              <td class="email-footer">
                <table role="presentation" width="100%" cellpadding="0" cellspacing="0" border="0" class="email-footer-card">
                  <tr>
                    <td>
                      <% if brand_logo_url.blank? && miru_logo_dark_url.present? %>
                        <div style="margin-bottom: 14px;">
                          <img src="<%= miru_logo_dark_url %>" width="80" alt="<%= t("mailers.layout.brand") %>" class="logo-light-mode" style="display: block; width: 80px; height: auto; margin: 0 auto; border: 0; outline: none; text-decoration: none;" />
                          <% if miru_logo_light_url.present? %>
                            <img src="<%= miru_logo_light_url %>" width="80" alt="<%= t("mailers.layout.brand") %>" class="logo-dark-mode" style="display: none; width: 80px; height: auto; margin: 0 auto; border: 0; outline: none; text-decoration: none;" />
                          <% end %>
                        </div>
                      <% end %>
                      <div><%= t("mailers.layout.footer_body") %></div>
                      <div style="margin-top: 12px;">
                        <a href="https://app.miru.so" target="_blank" class="email-footer-link"><%= t("mailers.layout.footer_site") %></a>
                        &nbsp;&middot;&nbsp;
                        <a href="mailto:<%= t("mailers.layout.footer_contact") %>" class="email-footer-link"><%= t("mailers.layout.footer_contact") %></a>
                      </div>
                      <div style="margin-top: 12px;"><%= t("mailers.layout.footer_copyright") %></div>
                    </td>
                  </tr>
                </table>
              </td>
            </tr>
          </table>
        </td>
      </tr>
    </table>
  </body>
</html>
