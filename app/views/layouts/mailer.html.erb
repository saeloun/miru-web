<!DOCTYPE html>
<html>
  <head>
    <meta http-equiv="Content-Type" content="text/html; charset=utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <meta name="color-scheme" content="light only" />
    <meta name="supported-color-schemes" content="light" />
    <style>
      :root {
        color-scheme: light only;
        supported-color-schemes: light;
      }

      body,
      table,
      td,
      a {
        -webkit-text-size-adjust: 100%;
        -ms-text-size-adjust: 100%;
      }

      table,
      td {
        mso-table-lspace: 0pt;
        mso-table-rspace: 0pt;
      }

      img {
        -ms-interpolation-mode: bicubic;
        border: 0;
        outline: none;
        text-decoration: none;
      }

      body {
        margin: 0;
        padding: 0;
        width: 100% !important;
        min-width: 100%;
        background-color: #f5f7fb;
        color: #020617;
        font-family: Inter, "Segoe UI", "Helvetica Neue", Arial, sans-serif;
      }

      a {
        color: #0f172a;
      }

      .email-shell {
        width: 100%;
        background:
          radial-gradient(circle at top, rgba(255, 255, 255, 0.96), rgba(255, 255, 255, 0) 26%),
          radial-gradient(circle at left top, rgba(15, 23, 42, 0.03), rgba(15, 23, 42, 0) 24%),
          linear-gradient(180deg, #f8fafc 0%, #edf2f7 100%);
        padding: 60px 16px;
      }

      .email-card {
        width: 100%;
        max-width: 720px;
        background-color: #ffffff;
        border: 1px solid #e5e7eb;
        border-radius: 30px;
        overflow: hidden;
        box-shadow: 0 28px 72px rgba(15, 23, 42, 0.08);
      }

      .email-card-inner {
        padding: 36px 38px 38px;
      }

      .email-brand {
        padding: 34px 38px 24px;
        text-align: center;
        background: linear-gradient(180deg, #ffffff 0%, #fbfcfd 100%);
        border-bottom: 1px solid #e5e7eb;
      }

      .email-brand-logo {
        display: block;
        width: 144px;
        height: auto;
        margin: 0 auto;
      }

      .email-eyebrow {
        margin: 20px 0 0;
        color: #64748b;
        font-size: 10px;
        font-weight: 700;
        letter-spacing: 0.22em;
        text-transform: uppercase;
      }

      .email-title {
        margin: 12px 0 0;
        color: #020617;
        font-size: 42px;
        font-weight: 700;
        line-height: 0.98;
        letter-spacing: -0.055em;
        max-width: 520px;
        margin-left: auto;
        margin-right: auto;
      }

      .email-subtitle {
        margin: 16px auto 0;
        max-width: 560px;
        color: #475569;
        font-size: 15px;
        line-height: 1.78;
        overflow-wrap: anywhere;
        word-break: break-word;
      }

      .email-body {
        color: #334155;
        font-size: 15px;
        line-height: 1.8;
        overflow-wrap: anywhere;
        word-break: break-word;
      }

      .email-body p {
        margin: 0 0 16px;
      }

      .email-body strong {
        color: #0f172a;
      }

      .email-highlight {
        margin: 24px 0;
        padding: 30px 24px;
        border: 1px solid #e7ebf0;
        border-radius: 22px;
        background: linear-gradient(180deg, #fbfcfe 0%, #f5f8fb 100%);
        box-shadow: inset 0 1px 0 rgba(255, 255, 255, 0.85);
        text-align: center;
      }

      .email-highlight-label {
        margin: 0 0 10px;
        color: #5b6b7f;
        font-size: 11px;
        font-weight: 700;
        letter-spacing: 0.14em;
        text-transform: uppercase;
      }

      .email-highlight-value {
        margin: 0;
        color: #020617;
        font-size: 40px;
        font-weight: 700;
        line-height: 1.08;
        letter-spacing: -0.05em;
      }

      .email-highlight-caption {
        margin: 12px 0 0;
        color: #475569;
        font-size: 14px;
        line-height: 1.65;
      }

      .email-list {
        margin: 0;
        padding-left: 20px;
      }

      .email-list li {
        margin: 0 0 10px;
      }

      .email-panel {
        margin: 24px 0;
        padding: 20px 22px;
        border-radius: 18px;
        border: 1px solid #e6ebf1;
        background-color: #ffffff;
      }

      .email-panel-soft {
        background: linear-gradient(180deg, #ffffff 0%, #fafbfd 100%);
      }

      .email-panel-accent {
        background: linear-gradient(180deg, #fbfcfd 0%, #f4f7fb 100%);
        border-color: #d5dde7;
      }

      .email-panel-success {
        border-color: rgba(22, 163, 74, 0.18);
        background: linear-gradient(180deg, rgba(240, 253, 244, 0.98) 0%, rgba(236, 253, 245, 0.92) 100%);
      }

      .email-panel-warning {
        border-color: rgba(245, 158, 11, 0.24);
        background: linear-gradient(180deg, rgba(245, 158, 11, 0.08) 0%, rgba(255, 251, 235, 0.95) 100%);
      }

      .email-panel-danger {
        border-color: rgba(239, 68, 68, 0.24);
        background: linear-gradient(180deg, rgba(239, 68, 68, 0.08) 0%, rgba(254, 242, 242, 0.95) 100%);
      }

      .email-panel-title {
        margin: 0 0 10px;
        color: #020617;
        font-size: 16px;
        font-weight: 600;
        line-height: 1.45;
      }

      .email-muted {
        color: #64748b;
      }

      .email-button-wrap {
        margin: 30px 0 0;
      }

      .email-button-cell {
        width: auto;
      }

      .email-button {
        display: inline-block;
        padding: 15px 24px;
        border-radius: 14px;
        background: #0f172a;
        color: #ffffff !important;
        font-size: 15px;
        font-weight: 700;
        line-height: 1;
        letter-spacing: 0.01em;
        text-decoration: none;
        box-shadow: 0 10px 24px rgba(15, 23, 42, 0.12);
      }

      .email-button-secondary {
        background: #ffffff;
        border: 1px solid #d2d9e2;
        color: #0f172a !important;
        box-shadow: none;
      }

      .email-divider {
        height: 1px;
        margin: 26px 0;
        background-color: #e2e8f0;
      }

      .detail-grid {
        width: 100%;
      }

      .detail-cell {
        width: 50%;
        padding: 0 8px 16px;
        vertical-align: top;
      }

      .detail-card {
        width: 100%;
        border: 1px solid #e7ebf0;
        border-radius: 18px;
        background-color: #ffffff;
        box-shadow: inset 0 1px 0 rgba(255, 255, 255, 0.85);
      }

      .detail-card td {
        padding: 18px 20px;
      }

      .detail-label {
        margin: 0 0 8px;
        color: #64748b;
        font-size: 11px;
        font-weight: 700;
        letter-spacing: 0.12em;
        text-transform: uppercase;
      }

      .detail-value {
        margin: 0;
        color: #0f172a;
        font-size: 18px;
        font-weight: 600;
        line-height: 1.45;
        overflow-wrap: anywhere;
        word-break: break-word;
      }

      .detail-subvalue {
        margin: 8px 0 0;
        color: #475569;
        font-size: 14px;
        line-height: 1.6;
        overflow-wrap: anywhere;
        word-break: break-word;
      }

      .email-fact-table {
        width: 100%;
        margin: 20px 0 0;
        border-collapse: collapse;
        border-top: 1px solid #e7ebf0;
        border-bottom: 1px solid #e7ebf0;
        background: linear-gradient(180deg, #ffffff 0%, #fcfcfd 100%);
        border-radius: 18px;
      }

      .email-fact-table td {
        padding: 15px 4px;
        border-bottom: 1px solid #e9edf2;
        vertical-align: top;
      }

      .email-fact-table tr:last-child td {
        border-bottom: 0;
      }

      .email-fact-key {
        color: #6b7280;
        font-size: 11px;
        line-height: 1.5;
        padding-right: 16px;
        text-transform: uppercase;
        letter-spacing: 0.08em;
      }

      .email-fact-value {
        color: #020617;
        font-size: 14px;
        font-weight: 600;
        line-height: 1.6;
        text-align: right;
        overflow-wrap: anywhere;
        word-break: break-word;
      }

      .email-footer {
        padding: 0 38px 34px;
      }

      .email-footer-card {
        border-radius: 18px;
        border: 1px solid #e6ebf1;
        background: linear-gradient(180deg, #ffffff 0%, #fafbfd 100%);
      }

      .email-footer-card td {
        padding: 16px 20px;
        color: #64748b;
        font-size: 12px;
        line-height: 1.7;
        text-align: center;
        overflow-wrap: anywhere;
        word-break: break-word;
      }

      .email-footer-link {
        color: #0f172a !important;
        text-decoration: none;
      }

      .digest-kicker {
        margin: 0 0 8px;
        color: #0f766e;
        font-size: 12px;
        font-weight: 600;
        text-transform: uppercase;
        letter-spacing: 0.12em;
      }

      .digest-value {
        margin: 0;
        color: #020617;
        font-size: 38px;
        font-weight: 700;
        line-height: 1.05;
      }

      .digest-caption {
        margin: 12px 0 0;
        color: #475569;
        font-size: 14px;
        line-height: 1.6;
      }

      .digest-trend-table {
        margin-top: 20px;
      }

      .digest-trend-cell {
        height: 88px;
        padding: 0 2px;
        vertical-align: bottom;
      }

      .digest-trend-bar {
        width: 100%;
        border-radius: 999px 999px 4px 4px;
        background: linear-gradient(180deg, rgba(15, 23, 42, 0.94) 0%, rgba(59, 130, 246, 0.3) 100%);
      }

      .digest-trend-labels {
        margin-top: 8px;
        color: #64748b;
        font-size: 12px;
      }

      .digest-source-name {
        padding: 10px 0;
        color: #111827;
        font-size: 14px;
        line-height: 1.5;
        border-bottom: 1px solid #e2e8f0;
      }

      .digest-source-amount {
        padding: 10px 0 10px 16px;
        color: #047857;
        font-size: 14px;
        font-weight: 600;
        line-height: 1.5;
        border-bottom: 1px solid #e2e8f0;
        white-space: nowrap;
      }

      .digest-empty-state {
        color: #64748b;
        font-size: 14px;
        line-height: 1.6;
      }

      @media only screen and (max-width: 640px) {
        .email-shell {
          padding: 18px 10px !important;
        }

        .email-card {
          border-radius: 24px !important;
        }

        .email-brand {
          padding: 24px 22px 22px !important;
        }

        .email-card-inner {
          padding: 28px 20px !important;
        }

        .email-footer {
          padding: 0 20px 20px !important;
        }

        .email-title {
          font-size: 30px !important;
        }

        .email-brand-logo {
          width: 124px !important;
        }

        .email-highlight {
          padding: 24px 18px !important;
        }

        .email-highlight-value {
          font-size: 32px !important;
        }

        .detail-cell,
        .stack-cell {
          display: block !important;
          width: 100% !important;
          padding-left: 0 !important;
          padding-right: 0 !important;
        }

        .email-fact-key,
        .email-fact-value {
          display: block !important;
          width: 100% !important;
          text-align: left !important;
          padding: 0 !important;
        }

        .email-fact-value {
          margin-top: 4px !important;
        }

        .email-button {
          display: block !important;
          width: 100% !important;
          box-sizing: border-box !important;
          text-align: center !important;
        }

        .email-button-wrap,
        .email-button-cell {
          width: 100% !important;
        }
      }

    </style>
  </head>
  <body style="margin: 0; padding: 0; width: 100%; min-width: 100%; background-color: #f5f7fb; color: #020617; font-family: Inter, 'Segoe UI', 'Helvetica Neue', Arial, sans-serif;">
    <% preheader = content_for?(:email_preheader) ? yield(:email_preheader).to_s.strip : t("mailers.layout.preheader") %>
    <div style="display: none; max-height: 0; overflow: hidden; opacity: 0; mso-hide: all;">
      <%= preheader %>
    </div>
    <table role="presentation" width="100%" cellpadding="0" cellspacing="0" border="0" class="email-shell" style="width: 100%; margin: 0; padding: 32px 16px; background-color: #f5f7fb; border-collapse: collapse;">
      <tr>
        <td align="center" style="padding: 0;">
          <table role="presentation" width="100%" cellpadding="0" cellspacing="0" border="0" class="email-card" style="width: 100%; max-width: 720px; background-color: #ffffff; border: 1px solid #e5e7eb; border-radius: 30px; overflow: hidden;">
            <tr>
              <td class="email-brand" style="padding: 34px 38px 24px; text-align: center; background-color: #ffffff; border-bottom: 1px solid #e5e7eb;">
                <table role="presentation" cellpadding="0" cellspacing="0" border="0" align="center">
                  <tr>
                    <td align="center">
                      <% if content_for?(:email_badge) %>
                        <%= yield :email_badge %>
                      <% else %>
                        <table role="presentation" cellpadding="0" cellspacing="0" border="0" align="center" aria-label="<%= t("mailers.layout.brand") %>" style="margin: 0 auto; border-collapse: collapse;">
                          <tr>
                            <td style="width: 34px; height: 34px; border-radius: 10px; background-color: #020617; color: #ffffff; font-size: 18px; font-weight: 800; line-height: 34px; text-align: center;">M</td>
                            <td style="padding-left: 10px; text-align: left;">
                              <div style="color: #020617; font-size: 22px; font-weight: 800; line-height: 1;">Miru</div>
                              <div style="margin-top: 4px; color: #64748b; font-size: 9px; font-weight: 700; letter-spacing: 0.18em; line-height: 1.2;">TRACK. BILL. GET PAID.</div>
                            </td>
                          </tr>
                        </table>
                      <% end %>
                    </td>
                  </tr>
                </table>
                <% if content_for?(:email_eyebrow) %>
                  <p class="email-eyebrow"><%= yield :email_eyebrow %></p>
                <% end %>
                <% if content_for?(:email_title) %>
                  <h1 class="email-title"><%= yield :email_title %></h1>
                <% end %>
                <% if content_for?(:email_subtitle) %>
                  <div class="email-subtitle"><%= yield :email_subtitle %></div>
                <% end %>
              </td>
            </tr>
            <tr>
              <td class="email-card-inner email-body">
                <%= yield %>
              </td>
            </tr>
            <tr>
              <td class="email-footer">
                <table role="presentation" width="100%" cellpadding="0" cellspacing="0" border="0" class="email-footer-card">
                  <tr>
                    <td>
                      <div><%= t("mailers.layout.footer_body") %></div>
                      <div style="margin-top: 12px;">
                        <a href="https://app.miru.so" target="_blank" class="email-footer-link"><%= t("mailers.layout.footer_site") %></a>
                        &nbsp;&middot;&nbsp;
                        <a href="mailto:<%= t("mailers.layout.footer_contact") %>" class="email-footer-link"><%= t("mailers.layout.footer_contact") %></a>
                      </div>
                      <div style="margin-top: 12px;"><%= t("mailers.layout.footer_copyright") %></div>
                    </td>
                  </tr>
                </table>
              </td>
            </tr>
          </table>
        </td>
      </tr>
    </table>
  </body>
</html>
