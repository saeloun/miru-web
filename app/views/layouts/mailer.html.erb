<!DOCTYPE html>
<html>
  <head>
    <meta http-equiv="Content-Type" content="text/html; charset=utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <style>
      body,
      table,
      td,
      a {
        -webkit-text-size-adjust: 100%;
        -ms-text-size-adjust: 100%;
      }

      table,
      td {
        mso-table-lspace: 0pt;
        mso-table-rspace: 0pt;
      }

      img {
        -ms-interpolation-mode: bicubic;
        border: 0;
        outline: none;
        text-decoration: none;
      }

      body {
        margin: 0;
        padding: 0;
        width: 100% !important;
        min-width: 100%;
        background-color: #edf2f7;
        color: #0f172a;
        font-family: "Aptos", "Segoe UI", "Helvetica Neue", Arial, sans-serif;
      }

      a {
        color: #2563eb;
      }

      .email-shell {
        width: 100%;
        background:
          radial-gradient(circle at top, rgba(148, 163, 184, 0.18), transparent 28%),
          linear-gradient(180deg, #f8fafc 0%, #eef2f7 50%, #e6ebf2 100%);
        padding: 40px 16px;
      }

      .email-card {
        width: 100%;
        max-width: 680px;
        background-color: #ffffff;
        border: 1px solid #dbe3ee;
        border-radius: 24px;
        overflow: hidden;
        box-shadow: 0 22px 50px rgba(15, 23, 42, 0.08);
      }

      .email-card-inner {
        padding: 34px 36px 36px;
      }

      .email-brand {
        padding: 28px 36px 24px;
        text-align: left;
        background:
          linear-gradient(180deg, #ffffff 0%, #fbfdff 72%, #f8fbff 100%);
        border-bottom: 1px solid #e6edf5;
      }

      .email-brand-logo {
        display: block;
        width: 132px;
        height: auto;
      }

      .email-eyebrow {
        margin: 20px 0 0;
        color: #475569;
        font-size: 10px;
        font-weight: 700;
        letter-spacing: 0.22em;
        text-transform: uppercase;
      }

      .email-title {
        margin: 12px 0 0;
        color: #0f172a;
        font-size: 40px;
        font-weight: 700;
        line-height: 1.02;
        letter-spacing: -0.04em;
      }

      .email-subtitle {
        margin: 16px 0 0;
        max-width: 560px;
        color: #475569;
        font-size: 15px;
        line-height: 1.75;
        overflow-wrap: anywhere;
        word-break: break-word;
      }

      .email-body {
        color: #334155;
        font-size: 16px;
        line-height: 1.75;
        overflow-wrap: anywhere;
        word-break: break-word;
      }

      .email-body p {
        margin: 0 0 16px;
      }

      .email-body strong {
        color: #0f172a;
      }

      .email-list {
        margin: 0;
        padding-left: 20px;
      }

      .email-list li {
        margin: 0 0 10px;
      }

      .email-panel {
        margin: 24px 0;
        padding: 22px 24px;
        border-radius: 20px;
        border: 1px solid #e2e8f0;
        background-color: #f8fafc;
      }

      .email-panel-soft {
        background: linear-gradient(180deg, #ffffff 0%, #f8fafc 100%);
      }

      .email-panel-accent {
        border-color: #dbeafe;
        background: linear-gradient(180deg, #f8fbff 0%, #eff6ff 100%);
      }

      .email-panel-success {
        border-color: #bbf7d0;
        background: linear-gradient(180deg, #f7fef9 0%, #f0fdf4 100%);
      }

      .email-panel-warning {
        border-color: rgba(245, 158, 11, 0.24);
        background: linear-gradient(180deg, rgba(245, 158, 11, 0.08) 0%, rgba(255, 251, 235, 0.95) 100%);
      }

      .email-panel-danger {
        border-color: rgba(239, 68, 68, 0.24);
        background: linear-gradient(180deg, rgba(239, 68, 68, 0.08) 0%, rgba(254, 242, 242, 0.95) 100%);
      }

      .email-panel-title {
        margin: 0 0 10px;
        color: #0f172a;
        font-size: 16px;
        font-weight: 600;
        line-height: 1.45;
      }

      .email-muted {
        color: #64748b;
      }

      .email-button-wrap {
        margin: 28px 0 0;
      }

      .email-button-cell {
        width: auto;
      }

      .email-button {
        display: inline-block;
        padding: 14px 22px;
        border-radius: 999px;
        background: #111827;
        color: #ffffff !important;
        font-size: 15px;
        font-weight: 700;
        line-height: 1;
        letter-spacing: 0.01em;
        text-decoration: none;
        box-shadow: 0 8px 20px rgba(15, 23, 42, 0.16);
      }

      .email-button-secondary {
        background: #ffffff;
        border: 1px solid #d5dde7;
        color: #0f172a !important;
        box-shadow: none;
      }

      .email-divider {
        height: 1px;
        margin: 26px 0;
        background-color: #e2e8f0;
      }

      .detail-grid {
        width: 100%;
      }

      .detail-cell {
        width: 50%;
        padding: 0 8px 16px;
        vertical-align: top;
      }

      .detail-card {
        width: 100%;
        border: 1px solid #e2e8f0;
        border-radius: 18px;
        background-color: #ffffff;
        box-shadow: 0 4px 14px rgba(15, 23, 42, 0.03);
      }

      .detail-card td {
        padding: 18px 20px;
      }

      .detail-label {
        margin: 0 0 8px;
        color: #64748b;
        font-size: 12px;
        font-weight: 700;
        letter-spacing: 0.12em;
        text-transform: uppercase;
      }

      .detail-value {
        margin: 0;
        color: #0f172a;
        font-size: 18px;
        font-weight: 600;
        line-height: 1.45;
        overflow-wrap: anywhere;
        word-break: break-word;
      }

      .detail-subvalue {
        margin: 8px 0 0;
        color: #475569;
        font-size: 14px;
        line-height: 1.6;
        overflow-wrap: anywhere;
        word-break: break-word;
      }

      .email-footer {
        padding: 0 38px 32px;
      }

      .email-footer-card {
        border-radius: 18px;
        border: 1px solid #e2e8f0;
        background: linear-gradient(180deg, #ffffff 0%, #f8fafc 100%);
      }

      .email-footer-card td {
        padding: 20px 24px;
        color: #64748b;
        font-size: 13px;
        line-height: 1.75;
        text-align: center;
        overflow-wrap: anywhere;
        word-break: break-word;
      }

      .email-footer-link {
        color: #334155 !important;
        text-decoration: none;
      }

      .digest-kicker {
        margin: 0 0 8px;
        color: #475569;
        font-size: 13px;
        font-weight: 600;
      }

      .digest-value {
        margin: 0;
        color: #111827;
        font-size: 40px;
        font-weight: 700;
        line-height: 1.05;
      }

      .digest-caption {
        margin: 12px 0 0;
        color: #475569;
        font-size: 14px;
        line-height: 1.6;
      }

      .digest-trend-table {
        margin-top: 20px;
      }

      .digest-trend-cell {
        height: 88px;
        padding: 0 2px;
        vertical-align: bottom;
      }

      .digest-trend-bar {
        width: 100%;
        border-radius: 999px 999px 4px 4px;
        background: linear-gradient(180deg, rgba(37, 99, 235, 0.92) 0%, rgba(59, 130, 246, 0.42) 100%);
      }

      .digest-trend-labels {
        margin-top: 8px;
        color: #64748b;
        font-size: 12px;
      }

      .digest-source-name {
        padding: 10px 0;
        color: #111827;
        font-size: 14px;
        line-height: 1.5;
        border-bottom: 1px solid #e2e8f0;
      }

      .digest-source-amount {
        padding: 10px 0 10px 16px;
        color: #15803d;
        font-size: 14px;
        font-weight: 600;
        line-height: 1.5;
        border-bottom: 1px solid #e2e8f0;
        white-space: nowrap;
      }

      .digest-empty-state {
        color: #64748b;
        font-size: 14px;
        line-height: 1.6;
      }

      @media (prefers-color-scheme: dark) {
        body {
          background-color: #0b1220 !important;
          color: #e5edf7 !important;
        }

        a {
          color: #93c5fd !important;
        }

        .email-shell {
          background:
            radial-gradient(circle at top, rgba(59, 130, 246, 0.16), transparent 24%),
            linear-gradient(180deg, #08111f 0%, #0f172a 54%, #131d31 100%) !important;
        }

        .email-card,
        .detail-card {
          background-color: #0f172a !important;
          border-color: rgba(148, 163, 184, 0.16) !important;
          box-shadow: 0 24px 60px rgba(2, 6, 23, 0.45) !important;
        }

        .email-brand {
          background: linear-gradient(180deg, rgba(15, 23, 42, 0.98) 0%, rgba(15, 23, 42, 0.92) 100%) !important;
          border-bottom-color: rgba(148, 163, 184, 0.14) !important;
        }

        .email-title,
        .email-panel-title,
        .detail-value,
        .email-body strong,
        .logo-label {
          color: #f8fafc !important;
        }

        .email-subtitle,
        .email-body,
        .detail-subvalue,
        .email-muted,
        .detail-label,
        .email-footer-card td,
        .digest-caption,
        .digest-trend-labels,
        .digest-empty-state {
          color: #94a3b8 !important;
        }

        .email-panel {
          background-color: rgba(15, 23, 42, 0.9) !important;
          border-color: rgba(148, 163, 184, 0.14) !important;
        }

        .email-panel-soft {
          background: linear-gradient(180deg, rgba(15, 23, 42, 0.95) 0%, rgba(15, 23, 42, 0.88) 100%) !important;
        }

        .email-panel-accent {
          background: linear-gradient(180deg, rgba(15, 23, 42, 0.96) 0%, rgba(30, 41, 59, 0.94) 100%) !important;
          border-color: rgba(96, 165, 250, 0.22) !important;
        }

        .email-panel-success {
          background: linear-gradient(180deg, rgba(6, 78, 59, 0.45) 0%, rgba(20, 83, 45, 0.4) 100%) !important;
          border-color: rgba(74, 222, 128, 0.2) !important;
        }

        .email-divider,
        .digest-source-name,
        .digest-source-amount {
          border-color: rgba(148, 163, 184, 0.16) !important;
          background-color: rgba(148, 163, 184, 0.16) !important;
        }

        .email-footer-card {
          background: linear-gradient(180deg, rgba(15, 23, 42, 0.94) 0%, rgba(17, 24, 39, 0.94) 100%) !important;
          border-color: rgba(148, 163, 184, 0.16) !important;
        }

        .email-footer-link {
          color: #e2e8f0 !important;
        }

        .email-button {
          background: #f8fafc !important;
          color: #0f172a !important;
          box-shadow: 0 10px 24px rgba(148, 163, 184, 0.16) !important;
        }

        .email-button-secondary {
          background: transparent !important;
          border-color: rgba(148, 163, 184, 0.2) !important;
          color: #f8fafc !important;
        }
      }

      @media only screen and (max-width: 640px) {
        .email-shell {
          padding: 18px 10px !important;
        }

        .email-card {
          border-radius: 24px !important;
        }

        .email-brand {
          padding: 24px 22px 22px !important;
        }

        .email-card-inner {
          padding: 28px 20px !important;
        }

        .email-footer {
          padding: 0 20px 20px !important;
        }

        .email-title {
          font-size: 30px !important;
        }

        .email-brand-logo {
          width: 118px !important;
        }

        .detail-cell,
        .stack-cell {
          display: block !important;
          width: 100% !important;
          padding-left: 0 !important;
          padding-right: 0 !important;
        }

        .email-button {
          display: block !important;
          width: 100% !important;
          box-sizing: border-box !important;
          text-align: center !important;
        }

        .email-button-wrap,
        .email-button-cell {
          width: 100% !important;
        }
      }

    </style>
  </head>
  <body>
    <% preheader = content_for?(:email_preheader) ? yield(:email_preheader).to_s.strip : t("mailers.layout.preheader") %>
    <div style="display: none; max-height: 0; overflow: hidden; opacity: 0; mso-hide: all;">
      <%= preheader %>
    </div>
    <table role="presentation" width="100%" cellpadding="0" cellspacing="0" border="0" class="email-shell">
      <tr>
        <td align="center">
          <table role="presentation" width="100%" cellpadding="0" cellspacing="0" border="0" class="email-card">
            <tr>
              <td class="email-brand">
                <table role="presentation" cellpadding="0" cellspacing="0" border="0" align="left">
                  <tr>
                    <td align="left">
                      <% if content_for?(:email_badge) %>
                        <%= yield :email_badge %>
                      <% else %>
                        <img src="<%= "#{root_url}miruLogoWithText.svg" %>" alt="<%= t("mailers.layout.brand") %>" width="132" class="email-brand-logo" style="display: block; width: 132px; height: auto;" />
                      <% end %>
                    </td>
                  </tr>
                </table>
                <% if content_for?(:email_eyebrow) %>
                  <p class="email-eyebrow"><%= yield :email_eyebrow %></p>
                <% end %>
                <% if content_for?(:email_title) %>
                  <h1 class="email-title"><%= yield :email_title %></h1>
                <% end %>
                <% if content_for?(:email_subtitle) %>
                  <div class="email-subtitle"><%= yield :email_subtitle %></div>
                <% end %>
              </td>
            </tr>
            <tr>
              <td class="email-card-inner email-body">
                <%= yield %>
              </td>
            </tr>
            <tr>
              <td class="email-footer">
                <table role="presentation" width="100%" cellpadding="0" cellspacing="0" border="0" class="email-footer-card">
                  <tr>
                    <td>
                      <div style="margin: 0 0 10px; color: #111827; font-size: 14px; font-weight: 600;"><%= t("mailers.layout.brand") %></div>
                      <div><%= t("mailers.layout.footer_body") %></div>
                      <div style="margin-top: 12px;">
                        <a href="https://app.miru.so" target="_blank" class="email-footer-link"><%= t("mailers.layout.footer_site") %></a>
                        &nbsp;&middot;&nbsp;
                        <a href="mailto:<%= t("mailers.layout.footer_contact") %>" class="email-footer-link"><%= t("mailers.layout.footer_contact") %></a>
                      </div>
                      <div style="margin-top: 12px;"><%= t("mailers.layout.footer_copyright") %></div>
                    </td>
                  </tr>
                </table>
              </td>
            </tr>
          </table>
        </td>
      </tr>
    </table>
  </body>
</html>
