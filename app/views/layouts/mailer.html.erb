<!DOCTYPE html>
<html>
  <head>
    <meta http-equiv="Content-Type" content="text/html; charset=utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <meta name="color-scheme" content="light only" />
    <meta name="supported-color-schemes" content="light" />
    <style>
      :root {
        color-scheme: light only;
        supported-color-schemes: light;
      }

      body,
      table,
      td,
      a {
        -webkit-text-size-adjust: 100%;
        -ms-text-size-adjust: 100%;
      }

      table,
      td {
        mso-table-lspace: 0pt;
        mso-table-rspace: 0pt;
      }

      img {
        -ms-interpolation-mode: bicubic;
        border: 0;
        outline: none;
        text-decoration: none;
      }

      body {
        margin: 0;
        padding: 0;
        width: 100% !important;
        min-width: 100%;
        background-color: #f8fafc;
        color: #020617;
        font-family: Inter, "Segoe UI", "Helvetica Neue", Arial, sans-serif;
      }

      a {
        color: #0f172a;
      }

      .email-shell {
        width: 100%;
        background: linear-gradient(180deg, #f8fafc 0%, #f1f5f9 100%);
        padding: 48px 16px;
      }

      .email-card {
        width: 100%;
        max-width: 720px;
        background-color: #ffffff;
        border: 1px solid #e2e8f0;
        border-radius: 24px;
        overflow: hidden;
        box-shadow: 0 12px 34px rgba(15, 23, 42, 0.05);
      }

      .email-card-inner {
        padding: 34px;
      }

      .email-brand {
        padding: 30px 34px 22px;
        text-align: center;
        background: linear-gradient(180deg, #ffffff 0%, #f8fafc 100%);
        border-bottom: 1px solid #e2e8f0;
      }

      .email-brand-logo {
        display: block;
        width: 140px;
        height: auto;
        margin: 0 auto;
      }

      .email-eyebrow {
        margin: 18px 0 0;
        color: #475569;
        font-size: 11px;
        font-weight: 700;
        letter-spacing: 0.18em;
        text-transform: uppercase;
      }

      .email-title {
        margin: 12px 0 0;
        color: #020617;
        font-size: 40px;
        font-weight: 700;
        line-height: 1.02;
        letter-spacing: -0.045em;
      }

      .email-subtitle {
        margin: 14px auto 0;
        max-width: 560px;
        color: #475569;
        font-size: 15px;
        line-height: 1.72;
        overflow-wrap: anywhere;
        word-break: break-word;
      }

      .email-body {
        color: #334155;
        font-size: 15px;
        line-height: 1.78;
        overflow-wrap: anywhere;
        word-break: break-word;
      }

      .email-body p {
        margin: 0 0 16px;
      }

      .email-body strong {
        color: #0f172a;
      }

      .email-highlight {
        margin: 24px 0;
        padding: 24px 22px;
        border: 1px solid #e2e8f0;
        border-radius: 20px;
        background: #f8fafc;
        text-align: center;
      }

      .email-highlight-label {
        margin: 0 0 10px;
        color: #64748b;
        font-size: 11px;
        font-weight: 700;
        letter-spacing: 0.14em;
        text-transform: uppercase;
      }

      .email-highlight-value {
        margin: 0;
        color: #020617;
        font-size: 34px;
        font-weight: 700;
        line-height: 1.08;
        letter-spacing: -0.04em;
      }

      .email-highlight-caption {
        margin: 12px 0 0;
        color: #475569;
        font-size: 14px;
        line-height: 1.65;
      }

      .email-list {
        margin: 0;
        padding-left: 20px;
      }

      .email-list li {
        margin: 0 0 10px;
      }

      .email-panel {
        margin: 24px 0;
        padding: 18px 20px;
        border-radius: 16px;
        border: 1px solid #e2e8f0;
        background-color: #ffffff;
      }

      .email-panel-soft {
        background: #ffffff;
      }

      .email-panel-accent {
        background: #f8fafc;
        border-color: #cbd5e1;
      }

      .email-panel-success {
        border-color: #bbf7d0;
        background: #f0fdf4;
      }

      .email-panel-warning {
        border-color: rgba(245, 158, 11, 0.24);
        background: linear-gradient(180deg, rgba(245, 158, 11, 0.08) 0%, rgba(255, 251, 235, 0.95) 100%);
      }

      .email-panel-danger {
        border-color: rgba(239, 68, 68, 0.24);
        background: linear-gradient(180deg, rgba(239, 68, 68, 0.08) 0%, rgba(254, 242, 242, 0.95) 100%);
      }

      .email-panel-title {
        margin: 0 0 10px;
        color: #020617;
        font-size: 15px;
        font-weight: 600;
        line-height: 1.45;
      }

      .email-muted {
        color: #64748b;
      }

      .email-button-wrap {
        margin: 28px 0 0;
      }

      .email-button-cell {
        width: auto;
      }

      .email-button {
        display: inline-block;
        padding: 14px 22px;
        border-radius: 12px;
        background: #0f172a;
        color: #ffffff !important;
        font-size: 15px;
        font-weight: 700;
        line-height: 1;
        letter-spacing: 0.01em;
        text-decoration: none;
        box-shadow: none;
      }

      .email-button-secondary {
        background: #ffffff;
        border: 1px solid #cbd5e1;
        color: #0f172a !important;
        box-shadow: none;
      }

      .email-divider {
        height: 1px;
        margin: 26px 0;
        background-color: #e2e8f0;
      }

      .detail-grid {
        width: 100%;
      }

      .detail-cell {
        width: 50%;
        padding: 0 8px 16px;
        vertical-align: top;
      }

      .detail-card {
        width: 100%;
        border: 1px solid #e2e8f0;
        border-radius: 16px;
        background-color: #ffffff;
        box-shadow: none;
      }

      .detail-card td {
        padding: 18px 20px;
      }

      .detail-label {
        margin: 0 0 8px;
        color: #64748b;
        font-size: 11px;
        font-weight: 700;
        letter-spacing: 0.08em;
        text-transform: uppercase;
      }

      .detail-value {
        margin: 0;
        color: #0f172a;
        font-size: 18px;
        font-weight: 600;
        line-height: 1.45;
        overflow-wrap: anywhere;
        word-break: break-word;
      }

      .detail-subvalue {
        margin: 8px 0 0;
        color: #475569;
        font-size: 14px;
        line-height: 1.6;
        overflow-wrap: anywhere;
        word-break: break-word;
      }

      .email-fact-table {
        width: 100%;
        margin: 18px 0 0;
        border-collapse: collapse;
        border-top: 1px solid #e2e8f0;
      }

      .email-fact-table td {
        padding: 14px 0;
        border-bottom: 1px solid #e7ebf0;
        vertical-align: top;
      }

      .email-fact-key {
        color: #64748b;
        font-size: 12px;
        line-height: 1.5;
        padding-right: 16px;
      }

      .email-fact-value {
        color: #020617;
        font-size: 14px;
        font-weight: 600;
        line-height: 1.6;
        text-align: right;
        overflow-wrap: anywhere;
        word-break: break-word;
      }

      .email-footer {
        padding: 0 34px 30px;
      }

      .email-footer-card {
        border-radius: 16px;
        border: 1px solid #e2e8f0;
        background: #ffffff;
      }

      .email-footer-card td {
        padding: 18px 20px;
        color: #64748b;
        font-size: 13px;
        line-height: 1.75;
        text-align: center;
        overflow-wrap: anywhere;
        word-break: break-word;
      }

      .email-footer-link {
        color: #0f172a !important;
        text-decoration: none;
      }

      .digest-kicker {
        margin: 0 0 8px;
        color: #475569;
        font-size: 12px;
        font-weight: 600;
        text-transform: uppercase;
        letter-spacing: 0.08em;
      }

      .digest-value {
        margin: 0;
        color: #020617;
        font-size: 36px;
        font-weight: 700;
        line-height: 1.05;
      }

      .digest-caption {
        margin: 12px 0 0;
        color: #475569;
        font-size: 14px;
        line-height: 1.6;
      }

      .digest-trend-table {
        margin-top: 20px;
      }

      .digest-trend-cell {
        height: 88px;
        padding: 0 2px;
        vertical-align: bottom;
      }

      .digest-trend-bar {
        width: 100%;
        border-radius: 999px 999px 4px 4px;
        background: linear-gradient(180deg, rgba(15, 23, 42, 0.92) 0%, rgba(148, 163, 184, 0.45) 100%);
      }

      .digest-trend-labels {
        margin-top: 8px;
        color: #64748b;
        font-size: 12px;
      }

      .digest-source-name {
        padding: 10px 0;
        color: #111827;
        font-size: 14px;
        line-height: 1.5;
        border-bottom: 1px solid #e2e8f0;
      }

      .digest-source-amount {
        padding: 10px 0 10px 16px;
        color: #15803d;
        font-size: 14px;
        font-weight: 600;
        line-height: 1.5;
        border-bottom: 1px solid #e2e8f0;
        white-space: nowrap;
      }

      .digest-empty-state {
        color: #64748b;
        font-size: 14px;
        line-height: 1.6;
      }

      @media only screen and (max-width: 640px) {
        .email-shell {
          padding: 18px 10px !important;
        }

        .email-card {
          border-radius: 24px !important;
        }

        .email-brand {
          padding: 24px 22px 22px !important;
        }

        .email-card-inner {
          padding: 28px 20px !important;
        }

        .email-footer {
          padding: 0 20px 20px !important;
        }

        .email-title {
          font-size: 30px !important;
        }

        .email-brand-logo {
          width: 124px !important;
        }

        .email-highlight {
          padding: 24px 18px !important;
        }

        .email-highlight-value {
          font-size: 30px !important;
        }

        .detail-cell,
        .stack-cell {
          display: block !important;
          width: 100% !important;
          padding-left: 0 !important;
          padding-right: 0 !important;
        }

        .email-fact-key,
        .email-fact-value {
          display: block !important;
          width: 100% !important;
          text-align: left !important;
          padding: 0 !important;
        }

        .email-fact-value {
          margin-top: 4px !important;
        }

        .email-button {
          display: block !important;
          width: 100% !important;
          box-sizing: border-box !important;
          text-align: center !important;
        }

        .email-button-wrap,
        .email-button-cell {
          width: 100% !important;
        }
      }

    </style>
  </head>
  <body>
    <% preheader = content_for?(:email_preheader) ? yield(:email_preheader).to_s.strip : t("mailers.layout.preheader") %>
    <div style="display: none; max-height: 0; overflow: hidden; opacity: 0; mso-hide: all;">
      <%= preheader %>
    </div>
    <table role="presentation" width="100%" cellpadding="0" cellspacing="0" border="0" class="email-shell">
      <tr>
        <td align="center">
          <table role="presentation" width="100%" cellpadding="0" cellspacing="0" border="0" class="email-card">
            <tr>
              <td class="email-brand">
                <table role="presentation" cellpadding="0" cellspacing="0" border="0" align="center">
                  <tr>
                    <td align="center">
                      <% if content_for?(:email_badge) %>
                        <%= yield :email_badge %>
                      <% else %>
                        <img src="<%= "#{root_url}miruLogoWithText.svg" %>" alt="<%= t("mailers.layout.brand") %>" width="132" class="email-brand-logo" style="display: block; width: 132px; height: auto;" />
                      <% end %>
                    </td>
                  </tr>
                </table>
                <% if content_for?(:email_eyebrow) %>
                  <p class="email-eyebrow"><%= yield :email_eyebrow %></p>
                <% end %>
                <% if content_for?(:email_title) %>
                  <h1 class="email-title"><%= yield :email_title %></h1>
                <% end %>
                <% if content_for?(:email_subtitle) %>
                  <div class="email-subtitle"><%= yield :email_subtitle %></div>
                <% end %>
              </td>
            </tr>
            <tr>
              <td class="email-card-inner email-body">
                <%= yield %>
              </td>
            </tr>
            <tr>
              <td class="email-footer">
                <table role="presentation" width="100%" cellpadding="0" cellspacing="0" border="0" class="email-footer-card">
                  <tr>
                    <td>
                      <div style="margin: 0 0 10px; color: #111827; font-size: 14px; font-weight: 600;"><%= t("mailers.layout.brand") %></div>
                      <div><%= t("mailers.layout.footer_body") %></div>
                      <div style="margin-top: 12px;">
                        <a href="https://app.miru.so" target="_blank" class="email-footer-link"><%= t("mailers.layout.footer_site") %></a>
                        &nbsp;&middot;&nbsp;
                        <a href="mailto:<%= t("mailers.layout.footer_contact") %>" class="email-footer-link"><%= t("mailers.layout.footer_contact") %></a>
                      </div>
                      <div style="margin-top: 12px;"><%= t("mailers.layout.footer_copyright") %></div>
                    </td>
                  </tr>
                </table>
              </td>
            </tr>
          </table>
        </td>
      </tr>
    </table>
  </body>
</html>
