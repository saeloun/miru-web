<% content_for :email_preheader, "#{@company.name}: #{@alert[:title]}" %>
<% content_for :email_eyebrow, "Analytics alert" %>
<% content_for :email_title, @alert[:title] %>
<% content_for :email_subtitle do %>
  <%= @alert[:message] %>
<% end %>

<div class="email-panel email-panel-warning">
  <p class="email-panel-title"><%= @company.name %></p>
  <p style="margin: 0;">Review this threshold alert in Miru before taking action.</p>
</div>

<% if @alert[:metadata].present? %>
  <%= render "shared/mailer/fact_rows",
    rows: @alert[:metadata].map { |key, value| { label: key.to_s.humanize, value: value } } %>
<% end %>

<%= render "shared/mailer/button", href: @analytics_url, label: "View analytics" %>
