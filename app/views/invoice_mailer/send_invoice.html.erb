<% content_for :email_preheader, t("mailers.invoice_mailer.send_invoice.preheader", invoice_number: @invoice.invoice_number, company_name: @invoice.company.name) %>
<% content_for :email_eyebrow, t("mailers.invoice_mailer.send_invoice.eyebrow") %>
<% content_for :email_title, t("mailers.invoice_mailer.send_invoice.title") %>
<% content_for :email_subtitle do %>
  <%= t("mailers.invoice_mailer.send_invoice.subtitle_html", company_name: @invoice.company.name, invoice_number: @invoice.invoice_number).html_safe %>
<% end %>

<% if @message.present? %>
  <div class="email-panel email-panel-soft">
    <p class="email-panel-title"><%= t("mailers.invoice_mailer.send_invoice.note_title", company_name: @invoice.company.name) %></p>
    <%= simple_format(@message, {}, wrapper_tag: "div") %>
  </div>
<% end %>

<div class="email-highlight">
  <p class="email-highlight-label"><%= t("mailers.labels.total_amount") %></p>
  <p class="email-highlight-value"><%= @amount || "-" %></p>
  <p class="email-highlight-caption"><%= t("mailers.invoice_mailer.send_invoice.next_steps_body") %></p>
</div>

<p class="email-panel-title"><%= t("mailers.invoice_mailer.send_invoice.next_steps_title") %></p>

<%= render "shared/mailer/fact_rows", rows: [
  { label: t("mailers.labels.invoice_number"), value: @invoice.invoice_number },
  { label: t("mailers.labels.issue_date"), value: l(@invoice.issue_date.to_date, format: :long) },
  { label: t("mailers.labels.due_date"), value: l(@invoice.due_date.to_date, format: :long) },
  { label: t("mailers.labels.reference"), value: @invoice.reference.presence || "-" },
  { label: t("mailers.labels.attachment"), value: t("mailers.invoice_mailer.send_invoice.attachment_value") }
] %>

<%= render "shared/mailer/button", href: @invoice_url, label: t("mailers.actions.open_invoice") %>

<p class="email-muted" style="margin-top: 18px;"><%= t("mailers.invoice_mailer.send_invoice.support_html", support_email: t("mailers.layout.footer_contact")).html_safe %></p>
