web: EMAIL_DELIVERY_METHOD=${EMAIL_DELIVERY_METHOD:-letter_opener_web} WEB_CONCURRENCY=${WEB_CONCURRENCY:-2} RAILS_MAX_THREADS=${RAILS_MAX_THREADS:-5} bundle exec falcon serve --bind http://0.0.0.0:${PORT:-3000}
vite: bin/vite dev
solidqueue: EMAIL_DELIVERY_METHOD=${EMAIL_DELIVERY_METHOD:-letter_opener_web} bundle exec rake solid_queue:start
